---
import { getCollection, render } from "astro:content";
import RecordDetailLayout from "@/components/detail/RecordDetailLayout.astro";
import { withBase } from "@/lib/paths";
import { isVisiblePublic } from "@/lib/visibility";
import { resolveRelatedRecords } from "@/lib/content";
import DiscussionSection from "@/components/discussion/DiscussionSection.astro";

export async function getStaticPaths() {
  const list = await getCollection("moments", ({ data }) => isVisiblePublic(data.visibility) && !data.draft);
  return list.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const d = entry.data;
const { Content } = await render(entry);
const related = await resolveRelatedRecords({ type: "moment", id: entry.id, tags: d.tags ?? [] }, d.related);
const text = d.content.trim();
const title = text.length > 24 ? text.slice(0, 24) + "…" : text;
const metas = [
  d.mood && { label: "◇", value: d.mood },
  d.weather && { label: "☁", value: d.weather },
  d.locationText && { label: "◎", value: d.locationText },
].filter(Boolean) as { label: string; value: string }[];
---

<RecordDetailLayout
  type="moment"
  title={title}
  summary={d.summary}
  date={d.date}
  updated={d.updatedAt}
  tags={d.tags ?? []}
  metas={metas}
  impact={d.worldlineImpact}
  featured={d.featured}
  worldlineWeight={d.worldlineWeight}
  related={related}
  backHref="/moments"
  backLabel="返回说说流"
>
  <p class="whitespace-pre-wrap text-lg leading-relaxed text-[var(--ia-ink)]">{text}</p>

  {d.images && d.images.length > 0 && (
    <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
      {d.images.map((img, i) => (
        <img src={withBase(img)} alt={`moment 图片 ${i + 1}`} loading="lazy" class="aspect-square w-full rounded-lg border border-[var(--ia-line)] object-cover" />
      ))}
    </div>
  )}

  <div class="ia-prose mt-8">
    <Content />
  </div>
  <DiscussionSection type="moment" recordId={entry.id} />
</RecordDetailLayout>
