---
import SiteLayout from"@/components/layout/SiteLayout.astro";import PageHeader from"@/components/common/PageHeader.astro";import EmptyState from"@/components/common/EmptyState.astro";import BugsFeed from"@/components/bugs/BugsFeed";import {getBugs}from"@/lib/content";import{withBase}from"@/lib/paths";const bugs=await getBugs();const items=bugs.map(x=>({id:x.id,title:x.data.title,summary:x.data.summary,date:x.data.date.toISOString(),tags:x.data.tags,href:withBase(`/bugs/${x.id}`),status:x.data.status,severity:x.data.severity}));
---
<SiteLayout title="Bug 战斗记录" description="每一场战斗与复盘。" motionScene="bugs"><PageHeader eyebrow="BUG LOG" title="Bug 战斗记录" subtitle="现象、根因、修复与复盘。" icon="bug" class="mb-6"/>{bugs.length?<BugsFeed client:load items={items}/>:<EmptyState icon="bug"/>}</SiteLayout>
