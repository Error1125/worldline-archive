---
import SiteLayout from "@/components/layout/SiteLayout.astro";
import PageHeader from "@/components/common/PageHeader.astro";
import BugCard from "@/components/cards/BugCard.astro";
import EmptyState from "@/components/common/EmptyState.astro";
import { getBugs } from "@/lib/content";

const bugs = await getBugs();

const fixed = bugs.filter((b) => b.data.status === "fixed").length;
const investigating = bugs.filter((b) => b.data.status === "investigating").length;
---

<SiteLayout title="Bug 战斗记录" description="与 Bug 的每一场战斗与复盘。">
  <PageHeader
    eyebrow="BUG LOG // 战斗记录"
    title="Bug 战斗记录"
    subtitle="每一个 Bug 都是一场小型战斗。这里记录现象、根因、修复与复盘。"
    icon="bug"
    class="mb-6"
  />

  <div class="mb-8 flex flex-wrap gap-3 mono text-xs">
    <span class="rounded-lg border border-[var(--ia-line)] bg-[var(--ia-panel)] px-3 py-1.5 text-[var(--ia-success)]">已修复 {fixed}</span>
    <span class="rounded-lg border border-[var(--ia-line)] bg-[var(--ia-panel)] px-3 py-1.5 text-[var(--ia-warning)]">调查中 {investigating}</span>
    <span class="rounded-lg border border-[var(--ia-line)] bg-[var(--ia-panel)] px-3 py-1.5 text-[var(--ia-mist)]">合计 {bugs.length}</span>
  </div>

  {
    bugs.length > 0 ? (
      <div class="grid gap-5 sm:grid-cols-2">
        {bugs.map((entry) => (
          <div class="reveal">
            <BugCard entry={entry} />
          </div>
        ))}
      </div>
    ) : (
      <EmptyState icon="bug" />
    )
  }
</SiteLayout>
