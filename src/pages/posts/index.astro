---
import SiteLayout from "@/components/layout/SiteLayout.astro";
import PageHeader from "@/components/common/PageHeader.astro";
import ArticleCard from "@/components/cards/ArticleCard.astro";
import EmptyState from "@/components/common/EmptyState.astro";
import { getPosts } from "@/lib/content";

const posts = await getPosts();
---

<SiteLayout title="文章" description="长文、开发记录与深夜思绪。">
  <PageHeader
    eyebrow="POSTS // 文章"
    title="文字档案"
    subtitle="写得比说说长一点的东西：开发记录、复盘、以及一些没头没尾的念头。"
    icon="post"
    class="mb-10"
  />

  {
    posts.length > 0 ? (
      <div class="grid gap-5 sm:grid-cols-2">
        {posts.map((entry) => (
          <div class="reveal">
            <ArticleCard entry={entry} />
          </div>
        ))}
      </div>
    ) : (
      <EmptyState icon="post" />
    )
  }
</SiteLayout>
