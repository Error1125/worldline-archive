---
import SiteLayout from"@/components/layout/SiteLayout.astro";import PageHeader from"@/components/common/PageHeader.astro";import EmptyState from"@/components/common/EmptyState.astro";import PostsFeed from"@/components/posts/PostsFeed";import {getPosts}from"@/lib/content";import{withBase}from"@/lib/paths";const posts=await getPosts();const items=posts.map(x=>({id:x.id,title:x.data.title,summary:x.data.summary??x.data.description,date:x.data.date.toISOString(),tags:x.data.tags,href:withBase(`/posts/${x.id}`),category:x.data.category}));
---
<SiteLayout title="文章" description="文字档案" motionScene="posts"><PageHeader eyebrow="POSTS // 文章" title="文字档案" subtitle="开发记录与思考。" icon="post" class="mb-10"/>{posts.length?<PostsFeed client:load items={items}/>:<EmptyState icon="post"/>}</SiteLayout>
