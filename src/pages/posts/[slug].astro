---
import { withBase } from "@/lib/paths";
import { getCollection, render } from "astro:content";
import SiteLayout from "@/components/layout/SiteLayout.astro";
import TagList from "@/components/common/TagList.astro";
import Icon from "@/components/common/Icon.astro";
import { formatDate } from "@/lib/format";
import { isVisiblePublic } from "@/lib/visibility";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => isVisiblePublic(data.visibility) && !data.draft);
  return posts.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, description, date, updated, tags, mood, category } = entry.data;
const { Content } = await render(entry);
---

<SiteLayout title={title} description={description}>
  <article class="mx-auto max-w-3xl">
    <!-- 返回 -->
    <a href={withBase("/posts")} class="clickable mb-6 inline-flex items-center gap-1.5 mono text-xs text-[var(--ia-mist)] transition-colors hover:text-[var(--ia-neon)]">
      <Icon name="arrow" size={13} class="rotate-180" /> 返回文章列表
    </a>

    <!-- 头部 -->
    <header class="reveal border-b border-[var(--ia-line)] pb-6">
      <div class="eyebrow flex items-center gap-1.5">
        <Icon name="post" size={13} class="text-[var(--ia-neon)]" /> POST // 文章
      </div>
      <h1 class="mt-3 text-3xl font-bold leading-tight tracking-tight text-[var(--ia-ink)] sm:text-4xl">
        {title}
      </h1>
      <p class="mt-3 text-base leading-relaxed text-[var(--ia-mist)]">{description}</p>
      <div class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 mono text-[11px] text-[var(--ia-mist)]">
        <time datetime={date.toISOString()}>发布 {formatDate(date)}</time>
        {updated && <time datetime={updated.toISOString()}>· 更新 {formatDate(updated)}</time>}
        {category && <span class="text-[var(--ia-neon)]">· {category}</span>}
        {mood && <span class="text-[var(--ia-nebula)]">· ◇ {mood}</span>}
      </div>
      {tags.length > 0 && <div class="mt-4"><TagList tags={tags} /></div>}
    </header>

    <!-- 正文 -->
    <div class="ia-prose reveal mt-8">
      <Content />
    </div>

    <!-- 页脚彩蛋 -->
    <footer class="mt-12 border-t border-[var(--ia-line)] pt-6 mono text-xs text-[var(--ia-mist)] opacity-70">
      <p>// end of record — 这段记忆已存档</p>
    </footer>
  </article>
</SiteLayout>
