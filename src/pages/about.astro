---
import { withBase } from "@/lib/paths";
import SiteLayout from "@/components/layout/SiteLayout.astro";
import GlassCard from "@/components/common/GlassCard.astro";
import Icon from "@/components/common/Icon.astro";
import { normalizeEmailHref } from "@/lib/contact";
import { siteConfig } from "@/config/site";
import ContactPop from "@/components/common/ContactPop.astro";
import profileSnapshot from "@/data/github/profile.json";
import contributionsSnapshot from "@/data/github/contributions.json";
import repoSnapshot from "@/data/github/repos.json";

const p = siteConfig.profile;
const links = siteConfig.links;
const github = (profileSnapshot as any).profile as any | null;
const contributionData = contributionsSnapshot as any;
const calendar = contributionData.available ? contributionData.calendar : null;
const contributionDays = calendar?.weeks?.flatMap((week: any) => week.contributionDays ?? []) ?? [];
const avatar = p.avatar || github?.avatarUrl || "";
const cover = p.cover || "";
const repos = (repoSnapshot.repos ?? []).slice(0, 4);
---

<SiteLayout title={p.aboutTitle || "关于我"} description={p.aboutSubtitle || p.bio}>
  <section class="reveal overflow-hidden rounded-3xl border border-[var(--ia-line)] bg-[var(--ia-panel)]">
    <div class="h-36 bg-[linear-gradient(125deg,color-mix(in_srgb,var(--ia-neon)_24%,transparent),color-mix(in_srgb,var(--ia-nebula)_28%,transparent))] sm:h-48">
      {cover && <img src={withBase(cover)} alt="" class="h-full w-full object-cover" />}
    </div>
    <div class="px-5 pb-6 sm:px-8">
      <div class="-mt-10 flex flex-col gap-4 sm:-mt-12 sm:flex-row sm:items-end">
        <span class="grid size-20 shrink-0 place-items-center overflow-hidden rounded-2xl border-4 border-[var(--ia-bg)] bg-[var(--ia-panel)] sm:size-24">
          {avatar ? <img src={withBase(avatar)} alt={siteConfig.author} class="h-full w-full object-cover" /> : <Icon name="user" size={36} />}
        </span>
        <div class="min-w-0 pb-1">
          <h1 class="text-2xl font-bold text-[var(--ia-ink)]">{siteConfig.author}</h1>
          <p class="mono text-sm text-[var(--ia-neon)]">{p.handle}</p>
        </div>
        <div class="flex flex-wrap gap-3 sm:ml-auto sm:pb-2">
          {links.github && <a href={links.github} target="_blank" rel="noopener noreferrer" class="clickable inline-flex items-center gap-1.5 text-xs text-[var(--ia-mist)] hover:text-[var(--ia-neon)]"><Icon name="github" size={14} /> GitHub</a>}
          {normalizeEmailHref(links.email) && <a href={normalizeEmailHref(links.email)} class="clickable text-xs text-[var(--ia-mist)] hover:text-[var(--ia-neon)]">Email</a>}
          {links.qq && <ContactPop icon="qq" label="QQ" account={links.qq} qr={links.qqQr || undefined} variant="text" />}
          {links.wechat && <ContactPop icon="wechat" label="WeChat" account={links.wechat} qr={links.wechatQr || undefined} variant="text" />}
          {links.bilibili && <a href={links.bilibili} target="_blank" rel="noopener noreferrer" class="clickable text-xs text-[var(--ia-mist)] hover:text-[var(--ia-neon)]">Bilibili</a>}
        </div>
      </div>
      <p class="mt-4 max-w-3xl text-sm leading-7 text-[var(--ia-mist)]">{p.bio}</p>
    </div>
  </section>

  <div class="mt-6 grid gap-6 lg:grid-cols-[1.2fr_.8fr]">
    <GlassCard class="reveal p-6">
      <span class="eyebrow">ABOUT ME</span>
      <h2 class="mt-2 text-xl font-bold text-[var(--ia-ink)]">{p.aboutTitle}</h2>
      <p class="mt-1 text-sm text-[var(--ia-neon)]">{p.aboutSubtitle}</p>
      <p class="mt-4 whitespace-pre-line text-sm leading-7 text-[var(--ia-mist)]">{p.aboutBody}</p>
    </GlassCard>
    <div class="grid gap-4 sm:grid-cols-3 lg:grid-cols-1">
      {[
        ["RESEARCH", p.researchAreas],
        ["TECH STACK", p.techStack],
        ["INTERESTS", p.interests],
      ].map(([label, items]) => (
        <GlassCard class="reveal p-4">
          <span class="mono text-[10px] tracking-wider text-[var(--ia-mist)]">{label as string}</span>
          <div class="mt-2 flex flex-wrap gap-1.5">{(items as readonly string[]).map((item) => <span class="tag-chip">{item}</span>)}</div>
        </GlassCard>
      ))}
    </div>
  </div>

  {p.showGithubContributions && (
    <GlassCard class="reveal mt-6 overflow-hidden p-5 sm:p-6">
      <div class="flex flex-wrap items-end justify-between gap-2">
        <div><span class="eyebrow">GITHUB CONTRIBUTIONS</span><h2 class="mt-1 text-lg font-bold text-[var(--ia-ink)]">代码贡献轨迹</h2></div>
        {calendar && <span class="mono text-xs text-[var(--ia-mist)]">{calendar.totalContributions} contributions</span>}
      </div>
      {calendar ? (
        <div class="mt-5 overflow-x-auto pb-2">
          <div class="contribution-grid min-w-[720px]" aria-label={`GitHub contributions: ${calendar.totalContributions}`}>
            {contributionDays.map((day: any) => <span title={`${day.date}: ${day.contributionCount}`} style={`background:${day.color || "var(--ia-line)"}`} />)}
          </div>
          <div class="mt-2 flex items-center justify-end gap-1 mono text-[10px] text-[var(--ia-mist)]"><span>Less</span>{[0,1,2,3,4].map((n) => <i style={`opacity:${.2 + n * .2}`} />)}<span>More</span></div>
        </div>
      ) : (
        <p class="mt-4 rounded-xl border border-[var(--ia-line)] p-4 text-sm text-[var(--ia-mist)]">GitHub contributions sync unavailable。请在 Admin 执行 GitHub 同步，并确保 Worker Token 可读取 GraphQL contributions。</p>
      )}
    </GlassCard>
  )}

  <div class="mt-6 grid gap-6 lg:grid-cols-2">
    <GlassCard class="reveal p-5">
      <span class="eyebrow">GITHUB PROFILE</span>
      {github ? <div class="mt-3 grid grid-cols-3 gap-3 text-center">{[["Repos", github.publicRepos], ["Followers", github.followers], ["Following", github.following]].map(([label, value]) => <div class="rounded-xl border border-[var(--ia-line)] p-3"><strong class="block text-lg text-[var(--ia-ink)]">{value}</strong><span class="mono text-[10px] text-[var(--ia-mist)]">{label}</span></div>)}</div> : <p class="mt-3 text-sm text-[var(--ia-mist)]">GitHub profile sync unavailable</p>}
    </GlassCard>
    <GlassCard class="reveal p-5">
      <span class="eyebrow">RECENT REPOSITORIES</span>
      <div class="mt-3 flex flex-col divide-y divide-[var(--ia-line)]">{repos.map((repo) => <a href={repo.url} target="_blank" rel="noopener noreferrer" class="clickable flex items-center justify-between gap-3 py-2.5 text-sm"><span class="truncate text-[var(--ia-ink)]">{repo.repo}</span><span class="mono shrink-0 text-[10px] text-[var(--ia-mist)]">★ {repo.stars} · {repo.language || "—"}</span></a>)}</div>
    </GlassCard>
  </div>
</SiteLayout>

<style>
  .contribution-grid { display: grid; grid-auto-flow: column; grid-template-rows: repeat(7, 11px); grid-auto-columns: 11px; gap: 3px; }
  .contribution-grid span, .contribution-grid + div i { width: 11px; height: 11px; border-radius: 2px; background: var(--ia-neon); }
</style>
