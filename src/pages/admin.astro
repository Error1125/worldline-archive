---
import { withBase } from "@/lib/paths";
import SiteLayout from "@/components/layout/SiteLayout.astro";
import GlassCard from "@/components/common/GlassCard.astro";
import Icon from "@/components/common/Icon.astro";

const capabilities: { icon: string; title: string; desc: string }[] = [
  { icon: "post", title: "在线发布文章", desc: "未来可直接在后台撰写、编辑、发布长文。" },
  { icon: "moment", title: "发布说说", desc: "随手记录碎碎念，带心情与天气。" },
  { icon: "photo", title: "上传照片", desc: "上传到对象存储，自动剥离 EXIF。" },
  { icon: "moment", title: "管理评论", desc: "审核 / 删除访客评论，基础反垃圾。" },
];
---

<SiteLayout title="后台" description="在线后台即将上线。">
  <div class="mx-auto max-w-2xl py-12">
    <div class="flex flex-col items-center text-center">
      <span class="grid size-16 place-items-center rounded-2xl icon-badge !text-[var(--ia-nebula)]">
        <Icon name="user" size={30} />
      </span>
      <div class="eyebrow mt-6">ADMIN // 后台</div>
      <h1 class="mt-2 text-2xl font-bold text-[var(--ia-ink)]">后台即将上线</h1>
      <p class="mt-3 max-w-md text-sm leading-relaxed text-[var(--ia-mist)]">
        第一版不做完整后台。未来这里将支持在线发布文章、说说、照片，以及管理评论。
        仅站长本人可进入。
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2">
      {
        capabilities.map((c) => (
          <GlassCard class="flex items-start gap-3 p-5">
            <span class="grid size-9 shrink-0 place-items-center rounded-lg border border-[var(--ia-line)] text-[var(--ia-neon)]">
              <Icon name={c.icon} size={17} />
            </span>
            <div>
              <div class="flex items-center gap-2">
                <h3 class="text-sm font-semibold text-[var(--ia-ink)]">{c.title}</h3>
                <span class="rounded-full border border-[var(--ia-line)] px-1.5 py-0.5 mono text-[9px] uppercase text-[var(--ia-nebula)]">soon</span>
              </div>
              <p class="mt-1 text-xs leading-relaxed text-[var(--ia-mist)]">{c.desc}</p>
            </div>
          </GlassCard>
        ))
      }
    </div>

    <div class="mt-8 rounded-xl border border-[var(--ia-line)] bg-[var(--ia-panel)] p-4 mono text-[11px] leading-relaxed text-[var(--ia-mist)]">
      <p class="text-[var(--ia-warning)]">// note</p>
      <p class="mt-1">后台入口默认不在主导航展示，仅在 features.auth 打开后于 Footer / About 角落出现。</p>
      <p>登录与权限见 src/lib/auth，第一版永远返回未登录。</p>
    </div>

    <div class="mt-8 text-center">
      <a href={withBase("/")} class="clickable inline-flex items-center gap-1.5 mono text-xs text-[var(--ia-mist)] transition-colors hover:text-[var(--ia-neon)]">
        <Icon name="arrow" size={13} class="rotate-180" /> 返回大厅
      </a>
    </div>
  </div>
</SiteLayout>
