---
import SiteLayout from "@/components/layout/SiteLayout.astro";

import HeroSearch from "@/components/home/HeroSearch.astro";
import ProfileCard from "@/components/home/ProfileCard.astro";
import FeaturedDeck from "@/components/home/FeaturedDeck.tsx";
import type { DeckItem } from "@/components/home/FeaturedDeck.tsx";
import NowPlayingCard from "@/components/home/NowPlayingCard.astro";
import TimelineTeaserCard from "@/components/home/TimelineTeaserCard.astro";
import AnimeHomeCard from "@/components/home/AnimeHomeCard.astro";
import SceneModeCard from "@/components/home/SceneModeCard.astro";
import HomeStatusStrip from "@/components/home/HomeStatusStrip.astro";

import {
  getPosts,
  getProjects,
  getAnime,
  getMusic,
  getPhotos,
  getBugs,
  getMoments,
  getWorldlineStatus,
  TYPE_META,
  type ContentType,
} from "@/lib/content";
import { withBase } from "@/lib/paths";
import { formatDate } from "@/lib/format";

const [posts, projects, anime, music, photos, bugs, moments] = await Promise.all([
  getPosts(),
  getProjects(),
  getAnime(),
  getMusic(),
  getPhotos(),
  getBugs(),
  getMoments(),
]);

// v3：Worldline Divergence 状态（按最近 30 天内容更新计算）
const worldlineStatus = await getWorldlineStatus();

const totalArchives =
  posts.length + projects.length + bugs.length + anime.length + music.length + photos.length + moments.length;

const counts = {
  posts: posts.length,
  projects: projects.length,
  archives: totalArchives,
  photos: photos.length,
};

const label = (t: ContentType) => `${TYPE_META[t].labelEn} // ${TYPE_META[t].labelZh}`;

const ACCENT: Record<ContentType, string> = {
  post: "var(--ia-neon)",
  project: "var(--ia-nebula)",
  photo: "var(--ia-blue)",
  anime: "var(--ia-success)",
  music: "var(--ia-warning)",
  bug: "var(--ia-danger)",
  moment: "var(--ia-star)",
};

const deckItems: DeckItem[] = [];

for (const p of posts.filter((x) => x.data.featured).slice(0, 2)) {
  deckItems.push({
    type: "post",
    typeLabel: label("post"),
    title: p.data.title,
    summary: p.data.description,
    date: formatDate(p.data.date),
    href: withBase(`/posts/${p.id}`),
    accent: ACCENT.post,
    image: p.data.cover ? withBase(p.data.cover) : undefined,
    imageDay: p.data.coverDay ? withBase(p.data.coverDay) : undefined,
    imageNight: p.data.coverNight ? withBase(p.data.coverNight) : undefined,
    imageAlt: p.data.title,
  });
}

const featProject = projects.find((x) => x.data.featured) ?? projects[0];
if (featProject) {
  deckItems.push({
    type: "project",
    typeLabel: label("project"),
    title: featProject.data.title,
    summary: featProject.data.description,
    date: formatDate(featProject.data.date),
    href: withBase("/projects"),
    accent: ACCENT.project,
    image: featProject.data.cover ? withBase(featProject.data.cover) : undefined,
    imageDay: featProject.data.coverDay ? withBase(featProject.data.coverDay) : undefined,
    imageNight: featProject.data.coverNight ? withBase(featProject.data.coverNight) : undefined,
    imageAlt: featProject.data.title,
  });
}

const latestPhoto = photos[0];
if (latestPhoto) {
  deckItems.push({
    type: "photo",
    typeLabel: label("photo"),
    title: latestPhoto.data.title,
    summary: latestPhoto.data.description ?? latestPhoto.data.album ?? "屏幕之外的光",
    date: formatDate(latestPhoto.data.date),
    href: withBase("/photos"),
    accent: ACCENT.photo,
    image: withBase(typeof latestPhoto.data.images[0] === "string" ? latestPhoto.data.images[0] : latestPhoto.data.images[0].url),
    imageAlt: latestPhoto.data.title,
  });
}

const latestAnimeEntry = anime[0];
if (latestAnimeEntry) {
  deckItems.push({
    type: "anime",
    typeLabel: label("anime"),
    title: latestAnimeEntry.data.title,
    summary:
      latestAnimeEntry.data.thoughts ??
      (latestAnimeEntry.data.score != null ? `观测评分 ${latestAnimeEntry.data.score}/10` : "观测名单中的一条世界线"),
    date: formatDate(latestAnimeEntry.data.date),
    href: withBase("/anime"),
    accent: ACCENT.anime,
    image: latestAnimeEntry.data.cover ? withBase(latestAnimeEntry.data.cover) : undefined,
    imageDay: latestAnimeEntry.data.coverDay ? withBase(latestAnimeEntry.data.coverDay) : undefined,
    imageNight: latestAnimeEntry.data.coverNight ? withBase(latestAnimeEntry.data.coverNight) : undefined,
    imageAlt: latestAnimeEntry.data.title,
  });
}

const latestMusicEntry = music[0];
if (latestMusicEntry) {
  const m = latestMusicEntry.data;
  deckItems.push({
    type: "music",
    typeLabel: label("music"),
    title: m.title,
    summary: m.comment ?? m.lyricsQuote ?? `${m.artist}${m.album ? ` · ${m.album}` : ""}`,
    date: formatDate(m.date),
    href: withBase("/music"),
    accent: ACCENT.music,
    image: m.cover ? withBase(m.cover) : undefined,
    imageDay: m.coverDay ? withBase(m.coverDay) : undefined,
    imageNight: m.coverNight ? withBase(m.coverNight) : undefined,
    imageAlt: m.title,
  });
}

type Recent = { date: Date; title: string; type: ContentType };
const recentAll: Recent[] = [
  ...posts.map((e) => ({ date: e.data.date, title: e.data.title, type: "post" as const })),
  ...projects.map((e) => ({ date: e.data.date, title: e.data.title, type: "project" as const })),
  ...anime.map((e) => ({ date: e.data.date, title: e.data.title, type: "anime" as const })),
  ...music.map((e) => ({ date: e.data.date, title: e.data.title, type: "music" as const })),
  ...photos.map((e) => ({ date: e.data.date, title: e.data.title, type: "photo" as const })),
  ...bugs.map((e) => ({ date: e.data.date, title: e.data.title, type: "bug" as const })),
  ...moments.map((e) => ({
    date: e.data.date,
    title: e.data.content.split("\n")[0].slice(0, 42),
    type: "moment" as const,
  })),
];

recentAll.sort((a, b) => b.date.getTime() - a.date.getTime());
const timelineLatest = recentAll[0] ? formatDate(recentAll[0].date) : undefined;
const timelineRecent = recentAll.slice(0, 2).map((r) => ({ title: r.title, typeLabel: label(r.type) }));

const ANIME_STATUS: Record<string, string> = {
  watching: "观测中",
  completed: "已看完",
  planned: "想看",
  paused: "暂停",
  dropped: "搁置",
};
const topAnime = anime[0];
const animeStatus = topAnime ? (ANIME_STATUS[topAnime.data.status] ?? "正在观测") : "正在观测";
const animeCover = topAnime?.data.cover ? withBase(topAnime.data.cover) : undefined;

const earliest = [posts, projects, anime, music, photos, bugs, moments]
  .map((list) => list.at(-1)?.data.date)
  .filter((d): d is Date => d instanceof Date)
  .reduce((min, d) => (d < min ? d : min), new Date());
const startDate = earliest.toISOString();
---

<SiteLayout home>
  <div class="home-stack flex flex-col gap-5 xl:h-full xl:min-h-0 xl:gap-6">
    <section class="reveal shrink-0 relative z-30">
      <HeroSearch />
    </section>

    <div
  class="home-grid grid min-h-0 grid-cols-1 gap-5 xl:flex-1 xl:grid-cols-[minmax(0,7fr)_minmax(0,5fr)] xl:grid-rows-[auto_560px] 2xl:grid-rows-[auto_585px]"
>
      <div class="reveal order-1 min-w-0 xl:order-none xl:col-start-1 xl:row-start-1">
        <ProfileCard counts={counts} />
      </div>

      <div class="reveal order-2 min-w-0 xl:order-none xl:col-start-2 xl:row-start-1">
        <NowPlayingCard />
      </div>

      <div class="reveal order-3 min-h-0 min-w-0 xl:order-none xl:col-start-1 xl:row-start-2">
        <FeaturedDeck client:visible items={deckItems} className="h-full" />
      </div>

      <div class="home-side-stack order-4 flex min-h-0 min-w-0 flex-col gap-5 xl:order-none xl:col-start-2 xl:row-start-2 xl:gap-5">
  <div class="reveal min-h-0 xl:h-[172px] 2xl:h-[178px] xl:flex-none">
    <TimelineTeaserCard count={totalArchives} latest={timelineLatest} recent={timelineRecent} status={worldlineStatus} class="h-full" />
  </div>

  <div class="reveal min-h-0 xl:flex-1">
    <AnimeHomeCard
      count={anime.length}
      latestTitle={topAnime?.data.title}
      statusLabel={animeStatus}
      cover={animeCover}
      class="h-full"
    />
  </div>

  <div class="reveal min-h-0 xl:h-[162px] 2xl:h-[168px] xl:flex-none">
    <SceneModeCard class="h-full" />
  </div>
</div>

    </div>

    <HomeStatusStrip startDate={startDate} class="shrink-0" />
  </div>
</SiteLayout>
