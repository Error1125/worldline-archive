---
import { withBase } from "@/lib/paths";

/**
 * /archive —— v4.1 兼容跳转页。
 * 「档案」已并入「世界线记录 · 观测索引」；此路由保留为兼容入口，
 * 跳转到 /timeline?view=index（若带 ?q= 则一并透传）。不改 astro.config / Actions。
 */
const target = withBase("/timeline");
const targetIndex = `${target}?view=index`;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <meta http-equiv="refresh" content={`0;url=${targetIndex}`} />
    <title>正在跳转 · 世界线记录</title>
    <script is:inline define:vars={{ target }}>
      (function () {
        try {
          var q = new URLSearchParams(location.search).get("q");
          location.replace(target + "?view=index" + (q ? "&q=" + encodeURIComponent(q) : ""));
        } catch (e) {
          location.replace(target + "?view=index");
        }
      })();
    </script>
    <style>
      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        background: #070a16;
        color: #c7d0e6;
        font-family: ui-sans-serif, system-ui, sans-serif;
      }
      a { color: #7aa2ff; }
    </style>
  </head>
  <body>
    <p>
      「档案」已并入 <a href={targetIndex}>世界线记录 · 观测索引</a>，正在跳转…
    </p>
  </body>
</html>
