---
import SiteLayout from "@/components/layout/SiteLayout.astro";
import PageHeader from "@/components/common/PageHeader.astro";
import EmptyState from "@/components/common/EmptyState.astro";
import ProjectsFeed from "@/components/projects/ProjectsFeed";
import {getProjects,PROJECT_STATUS_ZH} from "@/lib/content";
import {withBase} from "@/lib/paths";
const projects=await getProjects(); const labels:Record<string,string>={...PROJECT_STATUS_ZH,active:"活跃维护",completed:"已完成",prototype:"原型"};
const statuses=Object.entries(labels).map(([value,label])=>({value,label,count:projects.filter(x=>x.data.status===value).length})).filter(x=>x.count);
const all=new Map<string,number>();for(const p of projects)for(const t of p.data.techStack)all.set(t,(all.get(t)??0)+1);const techs=[...all].map(([value,count])=>({value,count}));
const repoUrl = (value: unknown): string | undefined => {
  if (typeof value === "string") return value;
  if (value && typeof value === "object" && "owner" in value && "repo" in value) {
    const { owner, repo } = value;
    if (typeof owner === "string" && typeof repo === "string") return `https://github.com/${owner}/${repo}`;
  }
  return undefined;
};
const items=projects.map(x=>({id:x.id,title:x.data.title,description:x.data.description,status:x.data.status,statusLabel:labels[x.data.status]??x.data.status,tech:x.data.techStack,tags:x.data.tags,date:x.data.date.toISOString(),href:withBase(`/projects/${x.id}`),repo:repoUrl(x.data.repo) ?? x.data.github,demo:x.data.demo,featured:x.data.featured}));
---
<SiteLayout title="项目" description="正在建造、暂停或已归档的造物。" motionScene="projects"><PageHeader eyebrow="PROJECTS // 造物记录" title="造物档案" subtitle="正在建造、暂停、或已经归档的东西。" icon="project" class="mb-8" />{projects.length?<ProjectsFeed client:load items={items} statuses={statuses} techs={techs}/>:<EmptyState icon="project"/>}</SiteLayout>
