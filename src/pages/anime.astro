---
import SiteLayout from "@/components/layout/SiteLayout.astro";
import PageHeader from "@/components/common/PageHeader.astro";
import EmptyState from "@/components/common/EmptyState.astro";
import AnimeFeed from "@/components/anime/AnimeFeed";
import { getAnime, ANIME_STATUS_ZH } from "@/lib/content";
import { withBase } from "@/lib/paths";
const anime = await getAnime();
const order=["watching","completed","planned","paused","dropped"];
const statuses=order.map(value=>({value,label:ANIME_STATUS_ZH[value]??value,count:anime.filter(x=>x.data.status===value).length})).filter(x=>x.count);
const tagMap=new Map<string,number>(); for(const item of anime) for(const tag of item.data.tags??[]) tagMap.set(tag,(tagMap.get(tag)??0)+1);
const tags=[...tagMap].map(([value,count])=>({value,count}));
const items=anime.map(x=>({id:x.id,title:x.data.title,titleJP:x.data.titleJP,status:x.data.status,statusLabel:ANIME_STATUS_ZH[x.data.status]??x.data.status,score:x.data.siteScore??x.data.score,episodes:x.data.episodes,currentEpisode:x.data.currentEpisode,cover:x.data.cover,tags:x.data.tags??[],thoughts:x.data.thoughts,date:x.data.date.toISOString(),href:withBase(`/anime/${x.id}`)}));
---
<SiteLayout title="番剧观测" description="番剧观测记录" motionScene="anime">
 <PageHeader eyebrow="ANIME // 番剧观测" title="番剧观测记录" subtitle="在看、看完与想看的作品。" icon="anime" class="mb-6" />
 {anime.length ? <AnimeFeed client:load items={items} statuses={statuses} tags={tags} /> : <EmptyState icon="anime" />}
</SiteLayout>
