---
import SiteLayout from"@/components/layout/SiteLayout.astro";import PageHeader from"@/components/common/PageHeader.astro";import EmptyState from"@/components/common/EmptyState.astro";import MusicPlayer from"@/components/music/MusicPlayer";import MusicFeed from"@/components/music/MusicFeed";import {getMusic}from"@/lib/content";const music=await getMusic();const labels:Record<string,string>={song:"单曲",album:"专辑",playlist:"歌单"};const kinds=Object.entries(labels).map(([value,label])=>({value,label,count:music.filter(x=>x.data.type===value).length})).filter(x=>x.count);const m=new Map<string,number>();for(const x of music)for(const t of x.data.tags)m.set(t,(m.get(t)??0)+1);const tags=[...m].map(([value,count])=>({value,count}));const items=music.map(x=>({id:x.id,title:x.data.title,artist:x.data.artist,album:x.data.album,type:x.data.type,cover:x.data.cover,tags:x.data.tags,comment:x.data.comment,url:x.data.appleMusicUrl,date:x.data.date.toISOString()}));
---
<SiteLayout title="音乐" description="深夜循环的歌。" motionScene="music"><PageHeader eyebrow="MUSIC // 音乐碎片" title="深夜循环" subtitle="最近喜欢的歌、专辑与歌单。" icon="music" class="mb-8"/><div class="mb-8"><MusicPlayer client:load/></div>{music.length?<MusicFeed client:load items={items} kinds={kinds} tags={tags}/>:<EmptyState icon="music"/>}</SiteLayout>
