---
import SiteLayout from "@/components/layout/SiteLayout.astro";
import PageHeader from "@/components/common/PageHeader.astro";
import MusicCard from "@/components/cards/MusicCard.astro";
import EmptyState from "@/components/common/EmptyState.astro";
import GlassCard from "@/components/common/GlassCard.astro";
import Icon from "@/components/common/Icon.astro";
import MusicPlayer from "@/components/music/MusicPlayer.tsx";
import AppleMusicConnectButton from "@/components/music/AppleMusicConnectButton.tsx";
import { getMusic } from "@/lib/content";

/**
 * Music 页面（v4.4）—— 音乐记录 / 歌单 / 歌词摘录 / 正在收听。
 * 顶部保留 NowPlaying + Apple Music 预留卡；下方统一 filter-bar：
 * 类型（单曲 / 专辑 / 歌单）+ 标签筛选 + 关键词搜索。
 * 卡片沿用 MusicCard（封面、艺术家、歌词摘录、个人评论、标签、Apple Music 外链）。
 */
const music = await getMusic();

const KIND_LABEL: Record<string, string> = { song: "单曲", album: "专辑", playlist: "歌单" };
const kindList = Object.keys(KIND_LABEL)
  .map((k) => ({ value: k, label: KIND_LABEL[k], count: music.filter((m) => m.data.type === k).length }))
  .filter((k) => k.count > 0);

const tagMap = new Map<string, number>();
for (const m of music) for (const t of m.data.tags) tagMap.set(t, (tagMap.get(t) ?? 0) + 1);
const tagList = [...tagMap.entries()].sort((a, b) => b[1] - a[1]).slice(0, 12).map(([value, count]) => ({ value, count }));
---

<SiteLayout title="音乐" description="深夜循环的歌、专辑与歌单碎片。" motionScene="music">
  <PageHeader
    eyebrow="MUSIC // 音乐碎片"
    title="深夜循环"
    subtitle="最近喜欢的歌、专辑与歌单。歌词是自己写的氛围短句，不搬运真实歌词。"
    icon="music"
    class="mb-8"
  />

  <!-- 正在收听 + Apple Music 预留 -->
  <div class="reveal mb-8 grid gap-4 lg:grid-cols-[minmax(0,1.5fr)_minmax(0,1fr)]">
    <GlassCard ticks class="flex flex-col gap-3 p-5">
      <span class="eyebrow">NOW PLAYING // 正在收听</span>
      <MusicPlayer client:load />
    </GlassCard>
    <GlassCard class="flex flex-col justify-center gap-3 p-5">
      <span class="eyebrow">APPLE MUSIC // 预留</span>
      <AppleMusicConnectButton client:load />
    </GlassCard>
  </div>

  {
    music.length > 0 ? (
      <div data-filter-root data-filter-kind="music">
        <div class="filter-panel mb-8 flex flex-col gap-4 p-4 sm:p-5">
          {kindList.length > 0 && (
            <div class="filter-bar">
              <span class="mono shrink-0 text-[11px] uppercase tracking-wider text-[var(--ia-mist)]">类型</span>
              <div class="filter-group" role="group" aria-label="按类型筛选">
                <button type="button" class="filter-chip" data-filter-chip data-key="type" data-value="all" data-active="true">
                  全部 <span class="chip-count">{music.length}</span>
                </button>
                {kindList.map((k) => (
                  <button type="button" class="filter-chip" data-filter-chip data-key="type" data-value={k.value}>
                    {k.label} <span class="chip-count">{k.count}</span>
                  </button>
                ))}
              </div>
            </div>
          )}

          {tagList.length > 0 && (
            <div class="filter-bar">
              <span class="mono shrink-0 text-[11px] uppercase tracking-wider text-[var(--ia-mist)]">标签</span>
              <div class="filter-group" role="group" aria-label="按标签筛选">
                <button type="button" class="filter-chip" data-filter-chip data-key="tag" data-value="all" data-active="true">
                  全部
                </button>
                {tagList.map((t) => (
                  <button type="button" class="filter-chip" data-filter-chip data-key="tag" data-value={t.value}>
                    #{t.value} <span class="chip-count">{t.count}</span>
                  </button>
                ))}
              </div>
            </div>
          )}

          <div class="filter-bar">
            <label class="filter-search">
              <Icon name="search" size={15} class="shrink-0 text-[var(--ia-mist)]" />
              <input type="search" data-filter-search placeholder="搜索歌曲 / 艺术家 / 专辑…" aria-label="搜索音乐" />
            </label>
            <span class="filter-count-line" data-filter-count data-filter-count-label="tracks">{music.length} tracks</span>
          </div>
        </div>

        <div class="filter-empty glass" data-filter-empty>
          <p class="text-sm text-[var(--ia-ink)]">没有匹配的音乐记录</p>
          <p class="mono mt-1 text-xs text-[var(--ia-mist)] opacity-70">// no tracks match this filter</p>
        </div>

        <div class="grid gap-5 sm:grid-cols-2" data-filter-list>
          {music.map((entry) => (
            <div
              class="reveal"
              data-filter-item
              data-type={entry.data.type}
              data-tag={entry.data.tags.join("|")}
              data-date={entry.data.date.toISOString()}
              data-search={[entry.data.title, entry.data.artist, entry.data.album ?? "", entry.data.comment ?? "", ...entry.data.tags].join(" ")}
            >
              <MusicCard entry={entry} />
            </div>
          ))}
        </div>
      </div>
    ) : (
      <EmptyState icon="music" />
    )
  }
</SiteLayout>
