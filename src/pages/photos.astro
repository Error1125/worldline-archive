---
import SiteLayout from "@/components/layout/SiteLayout.astro";
import PageHeader from "@/components/common/PageHeader.astro";
import PhotoCard from "@/components/cards/PhotoCard.astro";
import EmptyState from "@/components/common/EmptyState.astro";
import { getPhotos } from "@/lib/content";

/**
 * Photos 页面（v4.3）—— 照片墙 / 相册入口。
 * masonry 相册墙 + album 筛选；每张卡片代表一个 Album，并进入真实详情路由。
 */
const photos = await getPhotos();

// 相册（album）筛选选项（带数量）
const albumMap = new Map<string, number>();
for (const p of photos) {
  const a = p.data.album;
  if (a) albumMap.set(a, (albumMap.get(a) ?? 0) + 1);
}
const albums = [...albumMap.entries()].map(([value, count]) => ({ value, count }));
---

<SiteLayout title="照片" description="屏幕之外的光，与一些夜空观测。" motionScene="photos">
  <PageHeader
    eyebrow="PHOTOS // 相册"
    title="屏幕之外"
    subtitle="每个照片堆栈都是一册独立 Album；进入详情可浏览整组照片、说明与地点。"
    icon="photo"
    class="mb-8"
  />

  {
    photos.length > 0 ? (
      <div data-filter-root data-filter-kind="photos">
        {albums.length > 1 && (
          <div class="filter-panel mb-8 flex flex-col gap-3 p-4 sm:p-5">
            <div class="filter-bar">
              <span class="mono shrink-0 text-[11px] uppercase tracking-wider text-[var(--ia-mist)]">相册</span>
              <div class="filter-group" role="group" aria-label="按相册筛选">
                <button type="button" class="filter-chip" data-filter-chip data-key="album" data-value="all" data-active="true">
                  全部 <span class="chip-count">{photos.length}</span>
                </button>
                {albums.map((a) => (
                  <button type="button" class="filter-chip" data-filter-chip data-key="album" data-value={a.value}>
                    {a.value} <span class="chip-count">{a.count}</span>
                  </button>
                ))}
              </div>
              <span class="filter-count-line" data-filter-count data-filter-count-label="photos">{photos.length} photos</span>
            </div>
          </div>
        )}

        <div class="filter-empty glass" data-filter-empty>
          <p class="text-sm text-[var(--ia-ink)]">这个相册还没有照片</p>
          <p class="mono mt-1 text-xs text-[var(--ia-mist)] opacity-70">// no photos in this album</p>
        </div>

        <div class="photo-wall" data-filter-list>
          {photos.map((entry) => (
            <div
              class="reveal"
              data-filter-item
              data-album={entry.data.album ?? ""}
              data-date={entry.data.date.toISOString()}
              data-search={[entry.data.title, entry.data.description ?? "", entry.data.album ?? "", ...(entry.data.tags ?? [])].join(" ")}
            >
              <PhotoCard entry={entry} />
            </div>
          ))}
        </div>
      </div>
    ) : (
      <EmptyState icon="photo" />
    )
  }
</SiteLayout>
