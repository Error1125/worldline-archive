---
import SiteLayout from "@/components/layout/SiteLayout.astro";
import PageHeader from "@/components/common/PageHeader.astro";
import TimelineView from "@/components/timeline/TimelineView.astro";
import { getTimelineItems, getWorldlineStatus } from "@/lib/content";
import EmptyState from "@/components/common/EmptyState.astro";

const count = (await getTimelineItems()).length;
// v4 §11：复用世界线状态计算，在时间线页顶部做一个轻量状态徽标
const wl = await getWorldlineStatus();
---

<SiteLayout title="时间线" description="这条世界线上的全部记录，按时间倒序排列。">
  <div class="mb-10 flex flex-wrap items-end justify-between gap-4">
    <PageHeader
      eyebrow="TIMELINE // 时间线"
      title="世界线记录"
      subtitle="把文章、说说、番剧、音乐、项目与 Bug 混在一起，按时间倒序，像一条连续的存档轨迹。"
      icon="timeline"
      class="!mb-0"
    />
    <span class="wl-status" data-level={wl.level} title={wl.caption}>
      {wl.badge} · {wl.score}
    </span>
  </div>

  {count > 0 ? <TimelineView /> : <EmptyState icon="timeline" />}
</SiteLayout>
