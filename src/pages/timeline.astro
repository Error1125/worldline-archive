---
import SiteLayout from "@/components/layout/SiteLayout.astro";
import PageHeader from "@/components/common/PageHeader.astro";
import WorldlineRecordsExplorer from "@/components/worldline/WorldlineRecordsExplorer";
import { getTimelineItems, getWorldlineStatus, TYPE_META, type ContentType } from "@/lib/content";
import { withBase } from "@/lib/paths";
import EmptyState from "@/components/common/EmptyState.astro";

/**
 * 世界线记录（Worldline Records）—— v4.1 核心内容浏览页。
 * 合并原「时间线」与「档案聚合检索」为同页双视图：
 *   · 时间轴 / Timeline —— 按时间倒序浏览世界线故事（TimelineView）；
 *   · 观测索引 / Observation Index —— 按关键词/类型/标签检索全部内容（ArchiveExplorer，支持 ?q= 预填）。
 * 视图由 URL ?view= 决定（index → 观测索引），切换逻辑见 SiteLayout 的 view-toggle 控制器。
 */
const count = (await getTimelineItems()).length;
const wl = await getWorldlineStatus();
const colors: Record<ContentType,string>={post:"var(--ia-neon)",moment:"var(--ia-star)",bug:"var(--ia-danger)",project:"var(--ia-nebula)",anime:"var(--ia-success)",music:"var(--ia-warning)",photo:"var(--ia-blue)"};
const records=await getTimelineItems();
const explorerItems=records.map(x=>({id:`${x.type}:${x.id}`,type:x.type,label:TYPE_META[x.type].labelZh,title:x.title,description:x.description,date:x.date.toISOString(),href:x.href?withBase(x.href):undefined,tags:x.tags,color:colors[x.type]}));
const explorerTypes=(["post","project","photo","moment","bug","anime","music"] as ContentType[]).filter(t=>records.some(x=>x.type===t)).map(t=>({type:t,label:TYPE_META[t].labelZh,color:colors[t]}));
---

<SiteLayout title="世界线记录" description="这条世界线上的全部记录：按时间浏览，或按关键词检索。" motionScene="timeline">
  <div class="mb-8 flex flex-wrap items-end justify-between gap-4">
    <PageHeader
      eyebrow="WORLDLINE RECORDS // 世界线记录"
      title="世界线记录"
      subtitle="把文章、说说、番剧、音乐、项目与 Bug 混在一起——用「时间轴」顺着看故事，或用「观测索引」按关键词检索。"
      icon="timeline"
      class="!mb-0"
    />
    <span class="wl-status" data-level={wl.level} title={wl.caption}>
      {wl.badge} · {wl.score}
    </span>
  </div>

  {
    count > 0 ? (
      <div id="wl-records">
        <WorldlineRecordsExplorer client:load items={explorerItems} types={explorerTypes} initialView={Astro.url.searchParams.get("view") === "index" ? "observation" : "timeline"} />
      </div>
    ) : (
      <EmptyState icon="timeline" />
    )
  }
</SiteLayout>
