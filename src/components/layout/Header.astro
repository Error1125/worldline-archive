---
import { siteConfig } from "@/config/site";
import { mainNav, utilityNav } from "@/config/nav";
import Icon from "@/components/common/Icon.astro";
import { withBase } from "@/lib/paths";

/**
 * Header.astro —— 桌面端 sticky 毛玻璃头部。移动端隐藏（md 以下）。
 */
const path = Astro.url.pathname;
const search = utilityNav.find((n) => n.href === "/search");

function isActive(href: string): boolean {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
}
---

<header class="sticky top-0 z-40 hidden md:block">
  <div class="glass border-b border-[var(--ia-line)]">
    <div class="mx-auto flex h-16 max-w-6xl items-center gap-6 px-6">
      <!-- 站点标识 -->
      <a href={withBase("/")} class="clickable group flex items-baseline gap-2">
        <span class="text-base font-semibold tracking-wide text-[var(--ia-ink)]">
          {siteConfig.title}
        </span>
        <span class="mono text-[11px] text-[var(--ia-mist)] transition-colors group-hover:text-[var(--ia-neon)]">
          {siteConfig.subtitle}
        </span>
      </a>

      <!-- 主导航 -->
      <nav class="ml-auto flex items-center gap-1" aria-label="主导航">
        {
          mainNav.map((item) => {
            const active = isActive(item.href);
            return (
              <a
                href={withBase(item.href)}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "clickable group relative flex items-center gap-1.5 rounded-lg px-3 py-2 text-sm transition-colors",
                  active
                    ? "text-[var(--ia-ink)]"
                    : "text-[var(--ia-mist)] hover:text-[var(--ia-ink)]",
                ]}
              >
                <Icon
                  name={item.icon}
                  size={15}
                  class={active ? "text-[var(--ia-neon)]" : "opacity-70"}
                />
                <span>{item.label}</span>
                {active && (
                  <span class="pointer-events-none absolute inset-x-2 -bottom-px h-px bg-[var(--ia-neon)] shadow-[0_0_10px_var(--ia-neon)]" />
                )}
              </a>
            );
          })
        }
      </nav>

      <!-- 搜索入口 -->
      {
        search && (
          <a
            href={withBase(search.href)}
            aria-label="搜索"
            class="clickable grid size-9 place-items-center rounded-lg border border-[var(--ia-line)] text-[var(--ia-mist)] transition-colors hover:border-[var(--ia-neon)] hover:text-[var(--ia-neon)]"
          >
            <Icon name="search" size={16} />
          </a>
        )
      }
    </div>
  </div>
</header>
