---
import { siteConfig } from "@/config/site";
import { mainNav } from "@/config/nav";
import Icon from "@/components/common/Icon.astro";
import { withBase } from "@/lib/paths";

/**
 * Header.astro —— 桌面 / 平板端 sticky 顶栏。移动端隐藏（md 以下，由放射菜单承担导航）。
 * v3：去掉整条圆角胶囊外框，改为贴边的系统状态栏形态（毛玻璃 + 底部分割线，无大圆角）；
 * 局部元素（导航项 hover、搜索按钮）仍保留小圆角。
 * tablet（768–1079px）导航压缩为纯图标模式以避免横向挤压。
 * 首页（home）不显示右侧搜索 icon —— 搜索交给首页 HeroSearch。
 */
interface Props {
  home?: boolean;
}
const { home = false } = Astro.props;

const path = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
}
---

<header class="site-header sticky top-0 z-40 hidden md:block">
  <div class="site-topbar">
    <div class="site-header-shell mx-auto flex h-16 max-w-[1240px] min-w-0 items-center gap-5 px-6">
      <!-- 站点标识 -->
      <a href={withBase("/")} class="site-brand clickable group flex min-w-0 shrink-0 items-baseline gap-2">
        <span class="site-brand-title truncate text-[17px] font-semibold tracking-wide text-[var(--ia-ink)]">
          {siteConfig.title}
        </span>
        <span class="mono hidden min-w-0 truncate text-[11px] text-[var(--ia-mist)] transition-colors group-hover:text-[var(--ia-neon)] lg:inline">
          {siteConfig.subtitle}
        </span>
      </a>

      <!-- 主导航（全站主索引） -->
      <nav class="site-nav ml-auto flex min-w-0 items-center gap-0.5 overflow-x-auto py-1" aria-label="主导航">
        {
          mainNav.map((item) => {
            const active = isActive(item.href);
            return (
              <a
                href={withBase(item.href)}
                aria-current={active ? "page" : undefined}
                title={item.label}
                class:list={[
                  "site-nav-link clickable group relative flex min-w-0 items-center gap-1.5 rounded-lg px-2.5 py-2 text-[14px] transition-colors",
                  active
                    ? "font-semibold text-[var(--ia-ink)] bg-[color-mix(in_srgb,var(--ia-neon)_10%,transparent)]"
                    : "text-[var(--ia-mist)] hover:text-[var(--ia-ink)] hover:bg-[color-mix(in_srgb,var(--ia-star)_7%,transparent)]",
                ]}
              >
                <Icon
                  name={item.icon}
                  size={15}
                  class={active ? "text-[var(--ia-neon)]" : "opacity-70"}
                />
                <span class="site-nav-label truncate">{item.label}</span>
                {active && (
                  <span class="pointer-events-none absolute inset-x-2 -bottom-px h-0.5 rounded-full bg-[var(--ia-neon)] shadow-[0_0_10px_var(--ia-neon)]" />
                )}
              </a>
            );
          })
        }
      </nav>

      <!-- 搜索入口：首页隐藏（由 HeroSearch 承担）。内页 lg+ 显示紧凑搜索框
           （与 HeroSearch 共用建议下拉与键盘逻辑，Enter → /timeline?view=index&q=）；
           平板（md–lg）空间有限，退回图标入口，直达「观测索引」。 -->
      {
        !home && (
          <>
            <form
              action={withBase("/timeline")}
              method="get"
              role="search"
              aria-label="站内搜索"
              class="header-search clickable hidden shrink-0 lg:flex"
              data-wl-search
              autocomplete="off"
            >
              <input type="hidden" name="view" value="index" />
              <Icon name="search" size={15} class="shrink-0 opacity-70" />
              <input
                type="search"
                name="q"
                placeholder="搜索记录…"
                aria-label="搜索世界线记录"
                aria-autocomplete="list"
                aria-controls="header-search-suggest"
                data-wl-search-input
              />
              <div id="header-search-suggest" class="search-suggest" role="listbox" data-wl-search-panel hidden />
            </form>

            <a
              href={`${withBase("/timeline")}?view=index`}
              aria-label="搜索 / 观测索引"
              class="clickable grid size-9 shrink-0 place-items-center rounded-lg border border-[var(--ia-line)] text-[var(--ia-mist)] transition-colors hover:border-[var(--ia-neon)] hover:text-[var(--ia-neon)] lg:hidden"
            >
              <Icon name="search" size={16} />
            </a>
          </>
        )
      }
    </div>
  </div>
</header>
