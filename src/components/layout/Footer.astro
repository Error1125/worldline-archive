---
import { siteConfig } from "@/config/site";
import Icon from "@/components/common/Icon.astro";
import { withBase } from "@/lib/paths";

/**
 * Footer.astro —— 小型页脚。
 * - worldline rate 彩蛋；
 * - /admin 控制台入口（观测台）：仅登录后（localStorage wl-admin-hint）低调显示；权限在后端校验。
 */
const year = new Date().getFullYear();
const worldline = siteConfig.profile.worldline;
---

<footer class="relative z-10 mt-20 border-t border-[var(--ia-line)]">
  <div class="mx-auto flex max-w-6xl flex-col gap-3 px-6 py-8 text-xs text-[var(--ia-mist)] sm:flex-row sm:items-center sm:justify-between">
    <div class="flex flex-col gap-1">
      <span class="mono">
        © {year} {siteConfig.author} · {siteConfig.title}
      </span>
      <span class="mono opacity-70">
        // a personal save point in the isekai
      </span>
    </div>

    <div class="flex items-center gap-4">
      <!-- worldline 彩蛋 -->
      <span
        class="diamond mono text-[var(--ia-mist)]"
        title="World line divergence"
      >
        worldline {worldline}
      </span>

      <!-- v5.0 隐藏控制台入口：默认不渲染可见；登录成功后（localStorage wl-admin-hint=1）
           由下方 inline script 点亮。真正权限在后端逐请求校验，这里只是 UI 显隐。 -->
      <a
        id="wl-console-entry"
        href={withBase("/admin/dashboard")}
        class="clickable hidden items-center gap-1 text-[var(--ia-mist)] opacity-60 transition-opacity hover:opacity-100"
        aria-label="观测台入口"
      >
        <Icon name="lock" size={12} />
        <span class="mono">观测台 / console</span>
      </a>
      <script is:inline>
        (function () {
          function applyConsoleEntry() {
            var el = document.getElementById("wl-console-entry");
            if (!el) return;
            var on = false;
            try {
              on = localStorage.getItem("wl-admin-hint") === "1";
            } catch (e) {}
            el.classList.toggle("hidden", !on);
            el.classList.toggle("inline-flex", on);
          }
          applyConsoleEntry();
          document.addEventListener("astro:after-swap", applyConsoleEntry);
        })();
      </script>
    </div>
  </div>
</footer>
