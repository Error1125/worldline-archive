---
import { mobileNav } from "@/config/nav";
import Icon from "@/components/common/Icon.astro";
import { withBase } from "@/lib/paths";

/**
 * MobileNav.astro —— 移动端底部 TabBar。桌面端（md 及以上）隐藏。
 * 点击区域大、active 有柔和星光；配合 body 的 .main-has-tabbar 底部留白避免遮挡正文。
 */
const path = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === "/") return path === "/";
  return path === href || path.startsWith(href + "/");
}
---

<nav
  class="fixed inset-x-0 bottom-0 z-40 md:hidden pb-safe"
  aria-label="移动端导航"
>
  <div class="glass border-t border-[var(--ia-line)]">
    <ul class="mx-auto flex max-w-md items-stretch justify-around px-2">
      {
        mobileNav.map((item) => {
          const active = isActive(item.href);
          return (
            <li class="flex-1">
              <a
                href={withBase(item.href)}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "clickable relative flex min-h-14 flex-col items-center justify-center gap-1 px-1 py-2 text-[10px] transition-colors",
                  active ? "text-[var(--ia-ink)]" : "text-[var(--ia-mist)]",
                ]}
              >
                <span
                  class:list={[
                    "grid size-8 place-items-center rounded-xl transition-all",
                    active
                      ? "bg-[color-mix(in_srgb,var(--ia-neon)_16%,transparent)] text-[var(--ia-neon)] shadow-[0_0_16px_color-mix(in_srgb,var(--ia-neon)_45%,transparent)]"
                      : "text-current",
                  ]}
                >
                  <Icon name={item.icon} size={18} />
                </span>
                <span class="mono tracking-wide">{item.label}</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>
</nav>
