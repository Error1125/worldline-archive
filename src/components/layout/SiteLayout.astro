---
import "@/styles/global.css";
import { ClientRouter } from "astro:transitions";
import { siteConfig } from "@/config/site";
import { withBase } from "@/lib/paths";
import { getSearchIndex } from "@/lib/content";

import Header from "@/components/layout/Header.astro";
import MobileRadialMenu from "@/components/layout/MobileRadialMenu.tsx";
import Footer from "@/components/layout/Footer.astro";
import GlobalMusicPlayer from "@/components/music/GlobalMusicPlayer.tsx";

import Starfield from "@/components/effects/Starfield.tsx";
import SakuraPetals from "@/components/effects/SakuraPetals.tsx";
import SceneBackground from "@/components/effects/SceneBackground.tsx";
import WorldlineLoader from "@/components/effects/WorldlineLoader.tsx";
import { getTimelineItems } from "@/lib/content";
import { getWorldlineValue } from "@/lib/worldline";
import DanmakuBackground from "@/components/effects/DanmakuBackground.tsx";
import CustomCursor from "@/components/effects/CustomCursor.tsx";
import ClickSpark from "@/components/effects/ClickSpark.tsx";
import PageEnter from "@/components/effects/PageEnter.tsx";

/**
 * SiteLayout.astro —— 全站根布局。
 * - 引入 global.css，使用 View Transitions（ClientRouter）；
 * - 背景特效岛（星空 / 弹幕 / 光标 / 点击火花 / 进场扫光）均 client:only + transition:persist，
 *   路由切换时保持存活、背景不闪烁；
 * - z 轴：星云 z-0 → 特效 z-1/2 → 正文 z-10 → 头部 / 底栏 z-40。
 */
interface Props {
  title?: string;
  description?: string;
  /** 首页模式：主容器改用"观测室"一屏壳布局，且不渲染 Footer（由 HomeStatusStrip 收尾）。 */
  home?: boolean;
}
const { title, description, home = false } = Astro.props;

/* v5.0.2 §16.6：进场动画的世界线数值改由引擎在构建期计算（全站单一来源） */
const wlLoaderValue = getWorldlineValue(await getTimelineItems());
const pageTitle = title ? `${title} · ${siteConfig.title}` : `${siteConfig.title} · ${siteConfig.subtitle}`;
const pageDesc = description ?? siteConfig.description;

// v4.1：为「浏览器式站内搜索」（HeroSearch / Header）准备可 JSON 序列化的检索索引。
// href 预先经 withBase() 处理，客户端可直接跳转；indexHref 指向「世界线记录 · 观测索引」。
const rawIndex = await getSearchIndex();
const searchPayload = {
  indexHref: withBase("/timeline"),
  docs: rawIndex.map((d) => ({
    type: d.type,
    title: d.title,
    desc: d.description,
    typeLabel: d.typeLabelZh,
    href: withBase(d.href),
    date: d.date,
    search: d.search,
  })),
};
---

<!doctype html>
<html lang={siteConfig.language} data-wl-home={home ? "true" : "false"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () {
        var isHome = document.documentElement.dataset.wlHome === "true";
        var shouldBoot = false;
        try { shouldBoot = isHome && !sessionStorage.getItem("wl-loader-played") && !matchMedia("(prefers-reduced-motion: reduce)").matches; } catch (e) { shouldBoot = isHome; }
        document.documentElement.dataset.loaderState = shouldBoot ? "pending" : "complete";
        if (shouldBoot) window.setTimeout(function () { if (document.documentElement.dataset.loaderState !== "complete") document.documentElement.dataset.loaderState = "complete"; }, 5000);
      })();
    </script>
    <script is:inline>
      // 无闪烁昼夜模式（全站持久化）：
      // 1) paint 前依据 localStorage 设定 html[data-scene-mode]（默认 night）；
      // 2) View Transitions 换页会用新文档的 <html> 属性覆盖当前属性，
      //    因此在 astro:after-swap（DOM 交换后、绘制前）重新应用，避免「切到 Day 后进内页又变回夜间」。
      (function () {
        function readMode() {
          try {
            return localStorage.getItem("wl-scene-mode") === "day" ? "day" : "night";
          } catch (e) {
            return "night";
          }
        }
        function apply() {
          document.documentElement.dataset.sceneMode = readMode();
        }
        apply();
        document.addEventListener("astro:after-swap", apply);
      })();
    </script>
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <ClientRouter />
  </head>

  <body class="min-h-screen text-[var(--ia-ink)] antialiased">
    <div id="wl-boot" aria-hidden="true"><span class="mono">WORLDLINE ARCHIVE</span><i></i></div>
    <!-- 背景层：星云渐变（z-0），路由间持久化，避免闪烁 -->
    <div class="ia-nebula" transition:persist="nebula" aria-hidden="true"></div>

    <!-- 背景图轮播（z-0，DOM 在星云之后 / 星空之前）：无图或全部加载失败时自动退回纯星空 -->
    <SceneBackground client:only="react" transition:persist="scenebg" />

    <!-- 特效岛：全部 client:only（避免 SSR window 报错）+ 持久化 -->
    <Starfield client:only="react" transition:persist="starfield" />
    <SakuraPetals client:only="react" transition:persist="sakura" />
    <DanmakuBackground client:only="react" transition:persist="danmaku" />
    <CustomCursor client:only="react" transition:persist="cursor" />
    <ClickSpark client:only="react" transition:persist="spark" />
    <PageEnter client:only="react" transition:persist="page-enter" />

    <!-- 开场 Loader（首次会话播放一次，z-9990；sessionStorage 防重播） -->
    <WorldlineLoader client:only="react" transition:persist="wl-loader" value={wlLoaderValue} />

    <!-- 路由进场扫光条（由 PageEnter 触发 .run） -->
    <div class="page-sweep" aria-hidden="true"></div>

    <div class="wl-app">
    <Header home={home} />

    <main
      class:list={[
        "relative z-10 mx-auto w-full",
        home
          ? "home-shell max-w-[1180px] px-4 pt-5 pb-7 sm:px-6 sm:pt-6 xl:flex xl:flex-col xl:pb-5"
          : "max-w-6xl px-5 py-8 sm:px-6 sm:py-10",
      ]}
    >
      <slot />
    </main>

    {!home && <Footer />}

    <!-- 非首页全局音乐浮球（首页由 NowPlayingCard 承担，组件内部依据 pathname 自行隐藏）；
         transition:persist 保证换页时播放状态不丢失 -->
    <GlobalMusicPlayer client:only="react" transition:persist="global-music" />

    <!-- 移动端「全部入口」放射菜单（桌面隐藏；持久化避免路由闪烁） -->
    <MobileRadialMenu client:only="react" transition:persist="radial" />
    </div>

    <!-- 全站单例 Lightbox（照片墙点击放大；由下方脚本控制，默认隐藏） -->
    <div id="wl-lightbox" class="lightbox" data-open="false" role="dialog" aria-modal="true" aria-label="图片预览">
      <div class="lightbox-frame">
        <div class="lightbox-stage">
          <img class="lightbox-img" src="" alt="" />
          <button type="button" class="lightbox-btn lightbox-prev clickable" aria-label="上一张">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button type="button" class="lightbox-btn lightbox-next clickable" aria-label="下一张">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
          </button>
          <button type="button" class="lightbox-close clickable" aria-label="关闭">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        </div>
        <div class="lightbox-meta">
          <div>
            <div class="lightbox-title"></div>
            <div class="lightbox-desc"></div>
          </div>
          <time class="lightbox-date mono"></time>
        </div>
        <div class="lightbox-counter mono"></div>
      </div>
    </div>

    <!-- v4.1：站内搜索索引（HeroSearch / Header 读取；type=application/json 不作为脚本执行） -->
    <script
      id="wl-search-index"
      type="application/json"
      is:inline
      set:html={JSON.stringify(searchPayload).replace(/</g, "\\u003c")}
    />

    <!--
      SSR-safe 的客户端增强脚本：
      0) 全局昼夜模式控制器：委托 [data-scene-toggle] 点击，写入 localStorage 并广播事件；
      1) 卡片聚光：跟随鼠标更新 .glass-card 的 --spot-x / --spot-y；
      2) 进场浮现：IntersectionObserver 给 .reveal 加 .in。
      使用事件委托 + astro:page-load，兼容 View Transitions。
    -->
    <script>
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      // 0) 全局昼夜模式控制器（GlobalSceneModeController）
      const SCENE_KEY = "wl-scene-mode";
      type SceneMode = "night" | "day";

      function currentScene(): SceneMode {
        return document.documentElement.dataset.sceneMode === "day" ? "day" : "night";
      }
      function applyScene(mode: SceneMode) {
        document.documentElement.dataset.sceneMode = mode;
        try {
          localStorage.setItem(SCENE_KEY, mode);
        } catch {}
        syncSceneToggles();
        window.dispatchEvent(new CustomEvent("scene-mode-change", { detail: { mode } }));
      }
      function syncSceneToggles() {
        const mode = currentScene();
        document
          .querySelectorAll<HTMLElement>("[data-scene-toggle]")
          .forEach((b) => b.setAttribute("aria-pressed", mode === "day" ? "true" : "false"));
      }
      document.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement | null)?.closest?.("[data-scene-toggle]");
        if (!btn) return;
        applyScene(currentScene() === "day" ? "night" : "day");
      });
      document.addEventListener("keydown", (e) => {
        // 卡片本体是 <button>，Enter/Space 会触发 click；这里兜底其他宿主元素
        if (e.key !== "Enter" && e.key !== " ") return;
        const el = e.target as HTMLElement | null;
        if (el?.hasAttribute?.("data-scene-toggle") && el.tagName !== "BUTTON") {
          e.preventDefault();
          applyScene(currentScene() === "day" ? "night" : "day");
        }
      });
      syncSceneToggles();
      document.addEventListener("astro:page-load", syncSceneToggles);

      // 1) 卡片聚光 / spotlight（委托到 document）
      //    首页原有 .glass-card 光晕在此保留，并推广到 .spotlight-card / .interactive-card，
      //    使非卡片元素（如照片 tile）也能复用同一套跟随鼠标的光晕，无需复制 CSS。
      const SPOT_SEL = ".glass-card, .spotlight-card, .interactive-card";
      function onPointerMove(e: PointerEvent) {
        const target = e.target as HTMLElement | null;
        const card = target?.closest?.(SPOT_SEL) as HTMLElement | null;
        if (!card) return;
        const rect = card.getBoundingClientRect();
        card.style.setProperty("--spot-x", `${e.clientX - rect.left}px`);
        card.style.setProperty("--spot-y", `${e.clientY - rect.top}px`);
      }
      document.addEventListener("pointermove", onPointerMove, { passive: true });

      // 2) 进场浮现
      let observer: IntersectionObserver | null = null;
      function setupReveal() {
        if (reduceMotion) {
          document.querySelectorAll(".reveal").forEach((el) => el.classList.add("in"));
          return;
        }
        observer?.disconnect();
        observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("in");
                observer?.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.05 },
        );
        document.querySelectorAll(".reveal:not(.in)").forEach((el) => observer!.observe(el));
      }

      setupReveal();
      // View Transitions：每次换页后重新扫描
      document.addEventListener("astro:page-load", setupReveal);

      // 3) 通用「筛选栏」控制器（filter-bar）
      //    统一驱动 timeline / projects / photos / music / moments / archive 的
      //    类型 / 状态 / 标签 / 相册筛选 + 关键词搜索 + 排序，无需每页各写一套。
      //    约定（见各页 data-* 属性）：
      //      [data-filter-root]                 容器
      //        [data-filter-chip][data-key][data-value]   筛选胶囊（value=all 表示全部）
      //        [data-filter-search]             关键词输入（匹配 item 的 data-search）
      //        [data-filter-sort]               排序 select：newest | oldest
      //        [data-filter-empty]              无匹配空态
      //        [data-filter-item]               条目，携带 data-<key> / data-search / data-date
      //        [data-filter-group][data-group-key]  可选：分组容器（如年份），内含 [data-filter-list]
      type FilterState = Record<string, string>;
      function initFilterRoot(root: HTMLElement) {
        if (root.dataset.filterReady === "1") return;
        root.dataset.filterReady = "1";

        const chips = Array.from(root.querySelectorAll<HTMLElement>("[data-filter-chip]"));
        const items = Array.from(root.querySelectorAll<HTMLElement>("[data-filter-item]"));
        const groups = Array.from(root.querySelectorAll<HTMLElement>("[data-filter-group]"));
        const searchInput = root.querySelector<HTMLInputElement>("[data-filter-search]");
        const sortSelect = root.querySelector<HTMLSelectElement>("[data-filter-sort]");
        const emptyEl = root.querySelector<HTMLElement>("[data-filter-empty]");
        const countLine = root.querySelector<HTMLElement>("[data-filter-count]");

        const state: FilterState = {};
        chips.forEach((c) => {
          const key = c.dataset.key || "type";
          if (!(key in state)) state[key] = "all";
          if (c.dataset.active === "true") state[key] = c.dataset.value || "all";
        });

        // 初始搜索值（支持外部 ?q= 预填）：
        //   若容器声明 data-filter-query-param，则从 URL 读取该参数并预填搜索框，
        //   用于「Header / 首页搜索跳转到 /archive?q=xxx」的场景。
        const qp = root.dataset.filterQueryParam;
        if (qp && searchInput) {
          try {
            const fromUrl = new URLSearchParams(window.location.search).get(qp) || "";
            if (fromUrl) searchInput.value = fromUrl;
          } catch {}
        }
        let query = (searchInput?.value || "").trim().toLowerCase();
        let searchTimer = 0;

        function itemMatches(el: HTMLElement): boolean {
          for (const key of Object.keys(state)) {
            const val = state[key];
            if (val === "all") continue;
            const raw = (el.dataset[key] || "").toLowerCase();
            const set = raw.split(/[|,\s]+/).filter(Boolean);
            if (!set.includes(val.toLowerCase())) return false;
          }
          if (query) {
            const hay = (el.dataset.search || el.textContent || "").toLowerCase();
            if (!query.split(/\s+/).every((tk) => hay.includes(tk))) return false;
          }
          return true;
        }

        function apply() {
          const before = new Map(items.map((item) => [item, item.getBoundingClientRect()]));
          let visible = 0;
          for (const el of items) {
            const ok = itemMatches(el);
            if (ok) {
              el.hidden = false;
              el.dataset.filterState = "entering";
              requestAnimationFrame(() => { el.dataset.filterState = "shown"; });
            } else if (!el.hidden) {
              el.dataset.filterState = "leaving";
              window.setTimeout(() => { if (el.dataset.filterState === "leaving") el.hidden = true; }, reduceMotion ? 0 : 190);
            }
            if (ok) visible++;
          }
          // 分组：无可见条目则隐藏整组
          for (const g of groups) {
            const anyVisible = g.querySelector<HTMLElement>("[data-filter-item]:not([hidden])");
            g.hidden = !anyVisible;
          }
          if (emptyEl) emptyEl.dataset.show = visible === 0 ? "true" : "false";
          if (countLine) {
            const label = countLine.dataset.filterCountLabel || "records";
            countLine.textContent = `${visible} ${label}`;
          }
          if (!reduceMotion) requestAnimationFrame(() => {
            items.forEach((item, index) => {
              const old = before.get(item); const next = item.getBoundingClientRect();
              if (!old || item.hidden) return;
              const dx = old.left - next.left; const dy = old.top - next.top;
              if (dx || dy) {
                item.style.transition = "none";
                item.style.transform = `translate(${dx}px, ${dy}px)`;
                requestAnimationFrame(() => { item.style.transition = "transform var(--motion-base) var(--ease-spring-soft)"; item.style.transform = ""; });
              }
              item.style.setProperty("--filter-index", String(Math.min(index, 12)));
            });
          });
        }

        function sortNodes(dir: "newest" | "oldest") {
          const factor = dir === "oldest" ? 1 : -1;
          const byDate = (a: HTMLElement, b: HTMLElement) =>
            factor * ((+new Date(a.dataset.date || 0)) - (+new Date(b.dataset.date || 0)));
          if (groups.length) {
            const parent = groups[0].parentElement;
            const sortedGroups = [...groups].sort(
              (a, b) =>
                factor * ((+(a.dataset.groupKey || 0)) - (+(b.dataset.groupKey || 0))),
            );
            sortedGroups.forEach((g) => parent?.appendChild(g));
            for (const g of groups) {
              const list = g.querySelector<HTMLElement>("[data-filter-list]") || g;
              const its = Array.from(list.querySelectorAll<HTMLElement>("[data-filter-item]"));
              its.sort(byDate).forEach((n) => list.appendChild(n));
            }
          } else {
            const list =
              root.querySelector<HTMLElement>("[data-filter-list]") ||
              (items[0]?.parentElement as HTMLElement | null);
            if (list) {
              const its = Array.from(list.querySelectorAll<HTMLElement>("[data-filter-item]"));
              its.sort(byDate).forEach((n) => list.appendChild(n));
            }
          }
        }

        chips.forEach((chip) => {
          chip.addEventListener("click", () => {
            const key = chip.dataset.key || "type";
            state[key] = chip.dataset.value || "all";
            chips
              .filter((c) => (c.dataset.key || "type") === key)
              .forEach((c) => (c.dataset.active = c === chip ? "true" : "false"));
            apply();
          });
        });

        if (searchInput) {
          searchInput.addEventListener("input", () => {
            window.clearTimeout(searchTimer);
            searchTimer = window.setTimeout(() => { query = searchInput.value.trim().toLowerCase(); apply(); }, reduceMotion ? 0 : 100);
          });
        }
        if (sortSelect) {
          sortSelect.addEventListener("change", () => {
            sortNodes((sortSelect.value as "newest" | "oldest") || "newest");
            apply();
          });
        }

        apply();
      }
      function setupFilters() {
        document
          .querySelectorAll<HTMLElement>("[data-filter-root]")
          .forEach((root) => initFilterRoot(root));
      }
      setupFilters();
      document.addEventListener("astro:page-load", setupFilters);

      // 4) 通用 Lightbox（照片墙点击放大；全站单例）
      const lb = document.getElementById("wl-lightbox");
      if (lb) {
        const imgEl = lb.querySelector<HTMLImageElement>(".lightbox-img")!;
        const titleEl = lb.querySelector<HTMLElement>(".lightbox-title")!;
        const descEl = lb.querySelector<HTMLElement>(".lightbox-desc")!;
        const dateEl = lb.querySelector<HTMLElement>(".lightbox-date")!;
        const counterEl = lb.querySelector<HTMLElement>(".lightbox-counter")!;
        const btnPrev = lb.querySelector<HTMLElement>(".lightbox-prev")!;
        const btnNext = lb.querySelector<HTMLElement>(".lightbox-next")!;
        const btnClose = lb.querySelector<HTMLElement>(".lightbox-close")!;

        let images: string[] = [];
        let captions: string[] = [];
        let idx = 0;
        let triggerEl: HTMLElement | null = null;

        function render() {
          if (!images.length) return;
          idx = (idx + images.length) % images.length;
          imgEl.src = images[idx];
          imgEl.alt = titleEl.textContent || "图片预览";
          imgEl.classList.remove("is-error", "is-next", "is-prev");
          descEl.textContent = captions[idx] || "";
          descEl.style.display = captions[idx] ? "block" : "none";
          counterEl.textContent = `${idx + 1} / ${images.length}`;
          const multi = images.length > 1;
          btnPrev.style.display = multi ? "grid" : "none";
          btnNext.style.display = multi ? "grid" : "none";
        }
        const open = (trigger: HTMLElement) => {
          try {
            images = JSON.parse(trigger.dataset.images || "[]");
            captions = JSON.parse(trigger.dataset.captions || "[]");
          } catch {
            images = [];
            captions = [];
          }
          if (!images.length) return;
          triggerEl = trigger;
          idx = Number(trigger.dataset.index || 0);
          titleEl.textContent = trigger.dataset.title || "";
          if (!captions.length && trigger.dataset.desc) captions = images.map(() => trigger.dataset.desc || "");
          dateEl.textContent = trigger.dataset.date || "";
          render();
          lb.dataset.open = "true";
          document.body.style.overflow = "hidden";
          btnClose.focus();
        };
        const close = () => {
          lb.dataset.open = "false";
          document.body.style.overflow = "";
          triggerEl?.focus(); triggerEl = null;
        };
        const move = (direction: "next" | "prev") => { idx += direction === "next" ? 1 : -1; render(); imgEl.classList.add(direction === "next" ? "is-next" : "is-prev"); };

        document.addEventListener("click", (e) => {
          const trigger = (e.target as HTMLElement | null)?.closest?.(
            "[data-lightbox]",
          ) as HTMLElement | null;
          if (trigger) {
            e.preventDefault();
            open(trigger);
          }
        });
        btnPrev.addEventListener("click", () => {
          move("prev");
        });
        btnNext.addEventListener("click", () => {
          move("next");
        });
        btnClose.addEventListener("click", close);
        lb.addEventListener("click", (e) => {
          if (e.target === lb) close();
        });
        document.addEventListener("keydown", (e) => {
          if (lb.dataset.open !== "true") return;
          if (e.key === "Escape") close();
          else if (e.key === "ArrowLeft") {
            move("prev");
          } else if (e.key === "ArrowRight") {
            move("next");
          }
        });
        imgEl.addEventListener("error", () => { imgEl.classList.add("is-error"); descEl.textContent = "图片加载失败，请检查原始地址。"; });
        // 换页时关闭，避免残留
        document.addEventListener("astro:before-swap", close);
      }

      // 5) 浏览器式站内搜索（HeroSearch / Header 共用）
      //    数据来自 #wl-search-index（构建期注入，href 已经过 withBase）。
      //    输入即出建议；↑↓ 选择，Enter 打开选中项，未选中则进入「观测索引」并带上 q；Esc 关闭。
      interface WLDoc {
        type: string;
        title: string;
        desc: string;
        typeLabel: string;
        href: string;
        date: string;
        search: string;
      }
      const SEARCH_ACCENT: Record<string, string> = {
        post: "var(--ia-neon)",
        project: "var(--ia-nebula)",
        photo: "var(--ia-blue)",
        anime: "var(--ia-success)",
        music: "var(--ia-warning)",
        bug: "var(--ia-danger)",
        moment: "var(--ia-star)",
      };
      let SEARCH_DATA: { indexHref: string; docs: WLDoc[] } = { indexHref: "/", docs: [] };
      function loadSearchData() {
        const el = document.getElementById("wl-search-index");
        if (!el || !el.textContent) return;
        try {
          SEARCH_DATA = JSON.parse(el.textContent);
        } catch {}
      }
      loadSearchData();
      document.addEventListener("astro:page-load", loadSearchData);

      function fmtDate(iso: string): string {
        try {
          return new Date(iso).toISOString().slice(0, 10);
        } catch {
          return "";
        }
      }
      function escapeHtml(s: string): string {
        return s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" })[c] || c);
      }
      function searchDocs(q: string, limit = 8): WLDoc[] {
        const query = q.trim().toLowerCase();
        if (!query) return [];
        const tokens = query.split(/\s+/).filter(Boolean);
        const scored: { d: WLDoc; score: number }[] = [];
        for (const d of SEARCH_DATA.docs) {
          const hayTitle = d.title.toLowerCase();
          const hay = (d.search || d.title + " " + d.desc).toLowerCase();
          if (!tokens.every((t) => hay.includes(t))) continue;
          let score = 0;
          for (const t of tokens) {
            if (hayTitle.includes(t)) score += 5;
            if (hayTitle.startsWith(t)) score += 3;
          }
          scored.push({ d, score });
        }
        scored.sort((a, b) => b.score - a.score || +new Date(b.d.date) - +new Date(a.d.date));
        return scored.slice(0, limit).map((s) => s.d);
      }
      function initSearchBox(root: HTMLElement) {
        if (root.dataset.wlSearchReady === "1") return;
        root.dataset.wlSearchReady = "1";
        const input = root.querySelector<HTMLInputElement>("[data-wl-search-input]");
        const panel = root.querySelector<HTMLElement>("[data-wl-search-panel]");
        if (!input) return;
        let results: WLDoc[] = [];
        let active = -1;

        function goIndex() {
          const q = input!.value.trim();
          const base = SEARCH_DATA.indexHref || "/";
          window.location.href = base + "?view=index" + (q ? "&q=" + encodeURIComponent(q) : "");
        }
        function hide() {
          if (panel) {
            panel.hidden = true;
            panel.innerHTML = "";
          }
          active = -1;
          results = [];
        }
        function render() {
          if (!panel) return;
          if (!results.length) {
            hide();
            return;
          }
          let html = "";
          results.forEach((d, i) => {
            const acc = SEARCH_ACCENT[d.type] || "var(--ia-neon)";
            html +=
              `<a class="search-suggest-item" role="option" href="${d.href}" data-i="${i}" data-active="${i === active}" style="--ss-acc:${acc}">` +
              `<span class="search-suggest-badge">${escapeHtml(d.typeLabel)}</span>` +
              `<span class="search-suggest-main"><span class="search-suggest-title">${escapeHtml(d.title)}</span>` +
              (d.desc ? `<span class="search-suggest-desc">${escapeHtml(d.desc)}</span>` : "") +
              `</span>` +
              `<span class="search-suggest-meta"><span>${escapeHtml(d.typeLabel)}</span><time>${fmtDate(d.date)}</time></span>` +
              `</a>`;
          });
          html += `<div class="search-suggest-hint">↑↓ 选择 · Enter 打开 / 进入观测索引 · Esc 关闭</div>`;
          panel.innerHTML = html;
          panel.hidden = false;
        }
        function update() {
          results = searchDocs(input!.value, 8);
          active = -1;
          render();
        }
        input.addEventListener("input", update);
        input.addEventListener("focus", () => {
          if (input!.value.trim()) update();
        });
        input.addEventListener("keydown", (e) => {
          if (e.key === "ArrowDown") {
            if (results.length) {
              e.preventDefault();
              active = (active + 1) % results.length;
              render();
            }
          } else if (e.key === "ArrowUp") {
            if (results.length) {
              e.preventDefault();
              active = (active - 1 + results.length) % results.length;
              render();
            }
          } else if (e.key === "Enter") {
            if (active >= 0 && results[active]) {
              e.preventDefault();
              window.location.href = results[active].href;
            } else {
              e.preventDefault();
              goIndex();
            }
          } else if (e.key === "Escape") {
            hide();
          }
        });
        const form = root.tagName === "FORM" ? (root as HTMLFormElement) : root.querySelector("form");
        form?.addEventListener("submit", (e) => {
          if (active >= 0 && results[active]) {
            e.preventDefault();
            window.location.href = results[active].href;
            return;
          }
          e.preventDefault();
          goIndex();
        });
        document.addEventListener("click", (e) => {
          if (!root.contains(e.target as Node)) hide();
        });
      }
      function setupSearchBoxes() {
        document.querySelectorAll<HTMLElement>("[data-wl-search]").forEach((r) => initSearchBox(r));
      }
      setupSearchBoxes();
      document.addEventListener("astro:page-load", setupSearchBoxes);

      // 6) 视图切换（世界线记录：时间轴 / 观测索引）；以 URL ?view= 为准，兼容 View Transitions。
      function initViewRoot(root: HTMLElement) {
        if (root.dataset.viewReady === "1") return;
        root.dataset.viewReady = "1";
        const tabs = Array.from(root.querySelectorAll<HTMLElement>("[data-view-tab]"));
        function setView(v: string) {
          root.dataset.activeView = v;
          tabs.forEach((t) => t.setAttribute("aria-selected", t.dataset.viewTab === v ? "true" : "false"));
          try {
            const url = new URL(window.location.href);
            if (v === "index") url.searchParams.set("view", "index");
            else url.searchParams.delete("view");
            window.history.replaceState(null, "", url);
          } catch {}
        }
        tabs.forEach((t) => t.addEventListener("click", () => setView(t.dataset.viewTab || "timeline")));
        let initial = root.dataset.activeView || "timeline";
        try {
          if (new URLSearchParams(window.location.search).get("view") === "index") initial = "index";
        } catch {}
        setView(initial);
      }
      function setupViewRoots() {
        document.querySelectorAll<HTMLElement>("[data-view-root]").forEach((r) => initViewRoot(r));
      }
      setupViewRoots();
      document.addEventListener("astro:page-load", setupViewRoots);</script>
  </body>
</html>
