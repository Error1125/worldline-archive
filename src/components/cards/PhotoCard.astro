---
import type { CollectionEntry } from "astro:content";
import Icon from "@/components/common/Icon.astro";
import { formatDate } from "@/lib/format";
import { withBase } from "@/lib/paths";

/**
 * PhotoCard.astro（v4.1.2）—— 照片墙单元：拍立得 / 相纸 + 多图堆叠。
 * 去掉了旧的厚重 .glass-card 外壳，照片本身是主体：
 *   · 单图 → 一张拍立得相纸（浅色/深色相纸边框 + 标题日期 + 轻微旋转，角度由外层 nth-child 决定）；
 *   · 多图 → 主相纸下方叠 1~2 张错位照片，hover 时轻微展开。
 * 仍是全站单例 Lightbox 的触发器（button[data-lightbox]）；所有图片路径经 withBase()。
 */
interface Props {
  entry: CollectionEntry<"photos">;
}
const { entry } = Astro.props;
const { title, date, album, description, images, tags, mood } = entry.data;
const based = images.map((src) => withBase(src));
const cover = based[0];
const extra = based.length - 1;
---

<button
  type="button"
  class="photo-tile photo-stack group block w-full text-left"
  data-lightbox
  data-images={JSON.stringify(based)}
  data-title={title}
  data-date={formatDate(date)}
  data-desc={description ?? ""}
  aria-label={`打开相册预览：${title}`}
>
  {
    extra >= 2 && (
      <span class="photo-stack-back b2" aria-hidden="true">
        <span class="photo-stack-back-img" style={`background-image:url("${based[2]}")`} />
      </span>
    )
  }
  {
    extra >= 1 && (
      <span class="photo-stack-back b1" aria-hidden="true">
        <span class="photo-stack-back-img" style={`background-image:url("${based[1]}")`} />
      </span>
    )
  }

  <figure class="photo-polaroid">
    <div class="photo-polaroid-frame">
      <img src={cover} alt={title} loading="lazy" />
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/45 to-transparent"></div>
      {
        extra > 0 && (
          <div class="absolute bottom-2 right-2 flex items-center gap-1 rounded-full border border-[var(--ia-line-strong)] bg-black/45 px-2 py-0.5 mono text-[11px] text-[var(--ia-star)] backdrop-blur">
            <Icon name="photo" size={11} /> +{extra}
          </div>
        )
      }
      {album && <span class="absolute left-2 top-2 tag-chip backdrop-blur">{album}</span>}
      <span class="pointer-events-none absolute inset-0 grid place-items-center opacity-0 transition-opacity duration-300 group-hover:opacity-100">
        <span class="grid size-10 place-items-center rounded-full border border-white/40 bg-black/40 text-white backdrop-blur">
          <Icon name="search" size={16} />
        </span>
      </span>
    </div>

    <figcaption class="photo-polaroid-cap">
      <span class="photo-polaroid-title">{title}</span>
      <time class="photo-polaroid-date" datetime={date.toISOString()}>{formatDate(date)}</time>
    </figcaption>
    {
      (description || mood) && (
        <div class="px-0.5 pt-1 flex items-center justify-between gap-2">
          {description ? (
            <span class="line-clamp-1 text-[11px] leading-snug text-[var(--ia-mist)]">{description}</span>
          ) : (
            <span />
          )}
          {mood && <span class="shrink-0 mono text-[10px] text-[var(--ia-nebula)]">◇ {mood}</span>}
        </div>
      )
    }
    {
      tags && tags.length > 0 && (
        <div class="flex flex-wrap gap-1 px-0.5 pt-1.5">
          {tags.slice(0, 3).map((t) => (
            <span class="mono text-[10px] text-[var(--ia-mist)] opacity-70">#{t}</span>
          ))}
        </div>
      )
    }
  </figure>
</button>
