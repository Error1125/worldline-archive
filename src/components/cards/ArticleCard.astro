---
import type { CollectionEntry } from "astro:content";
import GlassCard from "@/components/common/GlassCard.astro";
import TagList from "@/components/common/TagList.astro";
import Icon from "@/components/common/Icon.astro";
import { formatDate } from "@/lib/format";

interface Props {
  entry: CollectionEntry<"posts">;
}
const { entry } = Astro.props;
const { title, description, date, tags, mood, category } = entry.data;
---

<GlassCard href={`/posts/${entry.id}`} ticks ariaLabel={title} class="group flex flex-col gap-3 p-5">
  <div class="flex items-center justify-between gap-3">
    <span class="eyebrow flex items-center gap-1.5">
      <Icon name="post" size={13} class="text-[var(--ia-neon)]" />
      POST // 文章
    </span>
    <time class="mono text-[11px] text-[var(--ia-mist)]" datetime={date.toISOString()}>
      {formatDate(date)}
    </time>
  </div>

  <h3 class="text-base font-semibold leading-snug text-[var(--ia-ink)] transition-colors group-hover:text-[var(--ia-star)]">
    {title}
  </h3>
  <p class="line-clamp-2 text-sm leading-relaxed text-[var(--ia-mist)]">{description}</p>

  <div class="mt-auto flex items-center justify-between gap-3 pt-1">
    <TagList tags={tags} max={3} />
    {mood && <span class="mono text-[11px] text-[var(--ia-nebula)]">◇ {mood}</span>}
    {!mood && category && <span class="mono text-[11px] text-[var(--ia-mist)]">{category}</span>}
  </div>
</GlassCard>
