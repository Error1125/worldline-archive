---
import type { CollectionEntry } from "astro:content";
import GlassCard from "@/components/common/GlassCard.astro";
import TagList from "@/components/common/TagList.astro";
import Icon from "@/components/common/Icon.astro";
import { formatDate } from "@/lib/format";
import { withBase } from "@/lib/paths";

interface Props {
  entry: CollectionEntry<"moments">;
}
const { entry } = Astro.props;
const { content, date, tags, mood, weather, locationText, images } = entry.data;
const meta = [mood, weather, locationText].filter(Boolean) as string[];
const pics = (images ?? []).slice(0, 3).map((src) => withBase(src));
---

<GlassCard class="group flex flex-col gap-3 p-5">
  <div class="flex items-center justify-between gap-3">
    <span class="eyebrow flex items-center gap-1.5">
      <Icon name="moment" size={13} class="text-[var(--ia-neon)]" />
      MOMENT // 说说
    </span>
    <time class="mono text-[11px] text-[var(--ia-mist)]" datetime={date.toISOString()}>
      {formatDate(date)}
    </time>
  </div>

  <p class="whitespace-pre-line text-[15px] leading-relaxed text-[var(--ia-ink)]">
    {content}
  </p>

  {
    pics.length > 0 && (
      <div class:list={["grid gap-2", pics.length === 1 ? "grid-cols-1" : "grid-cols-3"]}>
        {pics.map((src) => (
          <div class="aspect-square overflow-hidden rounded-lg border border-[var(--ia-line)]">
            <img
              src={src}
              alt=""
              loading="lazy"
              class="size-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
        ))}
      </div>
    )
  }

  <div class="mt-auto flex flex-wrap items-center gap-x-3 gap-y-1.5 pt-1">
    <TagList tags={tags ?? []} max={4} />
    {
      meta.length > 0 && (
        <span class="mono text-[11px] text-[var(--ia-mist)]">
          {meta.map((m) => `· ${m}`).join(" ")}
        </span>
      )
    }
  </div>
</GlassCard>
