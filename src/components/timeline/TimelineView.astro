---
import { getTimelineItems, TYPE_META, type TimelineItem } from "@/lib/content";
import Icon from "@/components/common/Icon.astro";
import TagList from "@/components/common/TagList.astro";
import { formatDate } from "@/lib/format";

/**
 * TimelineView.astro —— 完整时间线：混合所有集合，按日期倒序，按年份分组。
 * 每条带类型指示器（galgame / 终端风格的双语类型标签）。
 */
const items = await getTimelineItems();

// 按年份分组
const groups = new Map<number, TimelineItem[]>();
for (const it of items) {
  const y = it.date.getFullYear();
  if (!groups.has(y)) groups.set(y, []);
  groups.get(y)!.push(it);
}
const years = [...groups.keys()].sort((a, b) => b - a);

const dotColor: Record<string, string> = {
  post: "var(--ia-neon)",
  moment: "var(--ia-star)",
  bug: "var(--ia-danger)",
  project: "var(--ia-nebula)",
  anime: "var(--ia-success)",
  music: "var(--ia-warning)",
  photo: "var(--ia-mist)",
};
---

<div class="flex flex-col gap-10">
  {
    years.map((year) => (
      <section class="reveal">
        <div class="mb-4 flex items-center gap-3">
          <h2 class="font-serif text-3xl font-bold text-[var(--ia-ink)]">{year}</h2>
          <span class="mono text-[11px] text-[var(--ia-mist)]">
            {groups.get(year)!.length} records
          </span>
          <span class="h-px flex-1 bg-[var(--ia-line)]" />
        </div>

        <div class="relative pl-6">
          <span class="absolute bottom-2 left-[7px] top-2 w-px bg-gradient-to-b from-[var(--ia-line-strong)] via-[var(--ia-line)] to-transparent" />

          <ul class="flex flex-col gap-5">
            {groups.get(year)!.map((it) => {
              const Tag = it.href ? "a" : "div";
              const color = dotColor[it.type] ?? "var(--ia-mist)";
              return (
                <li class="relative">
                  <span
                    class="absolute -left-[21px] top-2 grid size-3.5 place-items-center rounded-full ring-2 ring-[#070a16]"
                    style={`background:${color};box-shadow:0 0 10px ${color}`}
                  />
                  <Tag
                    {...(it.href ? { href: it.href } : {})}
                    class:list={[
                      "glass-card group block rounded-xl p-4",
                      it.href && "clickable",
                    ]}
                  >
                    <div class="flex items-center gap-2">
                      <span
                        class="inline-flex items-center gap-1 rounded-md px-2 py-0.5 mono text-[10px] uppercase tracking-wider"
                        style={`color:${color};border:1px solid color-mix(in srgb, ${color} 40%, transparent)`}
                      >
                        <Icon name={TYPE_META[it.type].icon} size={11} />
                        {it.typeLabel}
                      </span>
                      <time class="ml-auto mono text-[11px] text-[var(--ia-mist)]" datetime={it.date.toISOString()}>
                        {formatDate(it.date)}
                      </time>
                    </div>
                    <h3 class="mt-2 text-[15px] font-semibold text-[var(--ia-ink)] transition-colors group-hover:text-[var(--ia-star)]">
                      {it.title}
                    </h3>
                    {it.description && (
                      <p class="mt-1 line-clamp-2 text-sm leading-relaxed text-[var(--ia-mist)]">
                        {it.description}
                      </p>
                    )}
                    {it.tags.length > 0 && (
                      <div class="mt-2">
                        <TagList tags={it.tags} max={5} />
                      </div>
                    )}
                  </Tag>
                </li>
              );
            })}
          </ul>
        </div>
      </section>
    ))
  }
</div>
