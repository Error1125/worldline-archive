---
import { withBase } from "@/lib/paths";
import { getTimelineItems, TYPE_META, type ContentType, type TimelineItem } from "@/lib/content";
import Icon from "@/components/common/Icon.astro";
import TagList from "@/components/common/TagList.astro";
import { formatDate } from "@/lib/format";

/**
 * TimelineView.astro —— 完整时间线（v4.1）。
 * 混合所有集合，按日期倒序，按年份分组；顶部提供统一 filter-bar：
 * 类型筛选（带数量）+ 关键词搜索 + 排序（最新 / 最早）。
 * 交互逻辑由 SiteLayout 的通用「filter-bar」控制器驱动（data-* 约定）。
 * 卡片沿用全站统一 .glass-card（模式感知，Day mode 不再灰黑）。
 */
const items = await getTimelineItems();

// 按年份分组
const groups = new Map<number, TimelineItem[]>();
for (const it of items) {
  const y = it.date.getFullYear();
  if (!groups.has(y)) groups.set(y, []);
  groups.get(y)!.push(it);
}
const years = [...groups.keys()].sort((a, b) => b - a);

const dotColor: Record<ContentType, string> = {
  post: "var(--ia-neon)",
  moment: "var(--ia-star)",
  bug: "var(--ia-danger)",
  project: "var(--ia-nebula)",
  anime: "var(--ia-success)",
  music: "var(--ia-warning)",
  photo: "var(--ia-blue)",
};

// 类型顺序 + 数量（供筛选胶囊使用）
const typeOrder: ContentType[] = ["post", "project", "photo", "moment", "bug", "anime", "music"];
const typeCounts = typeOrder.map((t) => ({
  type: t,
  count: items.filter((it) => it.type === t).length,
  labelZh: TYPE_META[t].labelZh,
  icon: TYPE_META[t].icon,
  color: dotColor[t],
}));
---

<div data-filter-root data-filter-kind="timeline">
  <!-- 统一筛选栏 -->
  <div class="glass-card mb-8 flex flex-col gap-4 p-4 sm:p-5">
    <div class="filter-bar">
      <div class="filter-group" role="group" aria-label="按类型筛选">
        <button type="button" class="filter-chip" data-filter-chip data-key="type" data-value="all" data-active="true">
          全部 <span class="chip-count">{items.length}</span>
        </button>
        {
          typeCounts
            .filter((t) => t.count > 0)
            .map((t) => (
              <button
                type="button"
                class="filter-chip"
                data-filter-chip
                data-key="type"
                data-value={t.type}
                style={`--acc:${t.color}`}
              >
                <span class="chip-dot" />
                {t.labelZh} <span class="chip-count">{t.count}</span>
              </button>
            ))
        }
      </div>
    </div>

    <div class="filter-bar">
      <label class="filter-search">
        <Icon name="search" size={15} class="shrink-0 text-[var(--ia-mist)]" />
        <input type="search" data-filter-search placeholder="在标题、摘要与标签中检索…" aria-label="搜索时间线记录" />
      </label>
      <select class="filter-sort" data-filter-sort aria-label="排序方式">
        <option value="newest">最新优先</option>
        <option value="oldest">最早优先</option>
      </select>
      <span class="filter-count-line" data-filter-count data-filter-count-label="records">{items.length} records</span>
    </div>
  </div>

  <!-- 无匹配空态 -->
  <div class="filter-empty glass" data-filter-empty>
    <p class="text-sm text-[var(--ia-ink)]">没有匹配的存档记录</p>
    <p class="mono mt-1 text-xs text-[var(--ia-mist)] opacity-70">// no records match this filter</p>
  </div>

  <div class="flex flex-col gap-10">
    {
      years.map((year) => (
        <section class="reveal" data-filter-group data-group-key={year}>
          <div class="mb-4 flex items-center gap-3">
            <h2 class="font-serif text-3xl font-bold text-[var(--ia-ink)]">{year}</h2>
            <span class="mono text-[11px] text-[var(--ia-mist)]">{groups.get(year)!.length} records</span>
            <span class="h-px flex-1 bg-[var(--ia-line)]" />
          </div>

          <div class="relative pl-6">
            <span class="absolute bottom-2 left-[7px] top-2 w-px bg-gradient-to-b from-[var(--ia-line-strong)] via-[var(--ia-line)] to-transparent" />

            <ul class="flex flex-col gap-5" data-filter-list>
              {groups.get(year)!.map((it) => {
                const Tag = it.href ? "a" : "div";
                const color = dotColor[it.type] ?? "var(--ia-mist)";
                const search = [it.title, it.description ?? "", it.typeLabel, ...it.tags].join(" ");
                return (
                  <li
                    class="relative"
                    data-filter-item
                    data-type={it.type}
                    data-date={it.date.toISOString()}
                    data-search={search}
                  >
                    <span
                      class="absolute -left-[21px] top-2 grid size-3.5 place-items-center rounded-full ring-2 ring-[var(--ia-bg)]"
                      style={`background:${color};box-shadow:0 0 10px ${color}`}
                    />
                    <Tag
                      {...(it.href ? { href: withBase(it.href) } : {})}
                      class:list={["glass-card group block rounded-xl p-4", it.href && "clickable"]}
                    >
                      <div class="flex items-center gap-2">
                        <span
                          class="inline-flex items-center gap-1 rounded-md px-2 py-0.5 mono text-[10px] uppercase tracking-wider"
                          style={`color:${color};border:1px solid color-mix(in srgb, ${color} 40%, transparent)`}
                        >
                          <Icon name={TYPE_META[it.type].icon} size={11} />
                          {it.typeLabel}
                        </span>
                        <time class="ml-auto mono text-[11px] text-[var(--ia-mist)]" datetime={it.date.toISOString()}>
                          {formatDate(it.date)}
                        </time>
                      </div>
                      <h3 class="mt-2 text-[15px] font-semibold text-[var(--ia-ink)] transition-colors group-hover:text-[var(--ia-star)]">
                        {it.title}
                      </h3>
                      {it.description && (
                        <p class="mt-1 line-clamp-2 text-sm leading-relaxed text-[var(--ia-mist)]">
                          {it.description}
                        </p>
                      )}
                      {it.tags.length > 0 && (
                        <div class="mt-2">
                          <TagList tags={it.tags} max={5} />
                        </div>
                      )}
                    </Tag>
                  </li>
                );
              })}
            </ul>
          </div>
        </section>
      ))
    }
  </div>
</div>
