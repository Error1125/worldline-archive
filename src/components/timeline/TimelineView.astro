---
import { withBase } from "@/lib/paths";
import { getTimelineItems, TYPE_META, type ContentType } from "@/lib/content";
import TimelineMotion from "@/components/timeline/TimelineMotion";

const items = await getTimelineItems();
const colors: Record<ContentType, string> = { post:"var(--ia-neon)", moment:"var(--ia-star)", bug:"var(--ia-danger)", project:"var(--ia-nebula)", anime:"var(--ia-success)", music:"var(--ia-warning)", photo:"var(--ia-blue)" };
const order: ContentType[] = ["post", "project", "photo", "moment", "bug", "anime", "music"];
const motionItems = items.map((item) => ({ id:item.id, type:item.type, typeLabel:item.typeLabel, title:item.title, description:item.description, date:item.date.toISOString(), href:item.href ? withBase(item.href) : undefined, tags:item.tags, color:colors[item.type] }));
const types = order.map((type) => ({type,label:TYPE_META[type].labelZh,count:items.filter((item)=>item.type===type).length,color:colors[type]})).filter((type)=>type.count>0);
---

<TimelineMotion client:load items={motionItems} types={types} />
