---
import Icon from "@/components/common/Icon.astro";
import { withBase } from "@/lib/paths";

interface Props {
  count: number;
  latestTitle?: string;
  statusLabel?: string;
  cover?: string;
  class?: string;
}

const { count, latestTitle, statusLabel = "正在观测", cover, class: className = "" } = Astro.props;
---

<a
  href={withBase("/anime")}
  class:list={["anime-card glass-card clickable group flex flex-col", className]}
  style={cover ? `--anime-cover: url("${cover}")` : undefined}
  data-has-cover={cover ? "true" : "false"}
  aria-label={`查看番剧观测，共 ${count} 部`}
>
  <div class="anime-card-inner flex flex-col">
    <div class="flex items-center justify-between gap-3">
      <span class="eyebrow flex items-center gap-2">
        <Icon name="anime" size={14} class="text-[var(--ia-nebula)]" />
        ANIME SIGNAL
      </span>
      <span class="anime-pulse mono flex items-center gap-1.5">
        <span class="anime-dot" aria-hidden="true"></span>
        {statusLabel}
      </span>
    </div>

    <div class="anime-copy min-w-0">
      <div class="mono anime-kicker">NOW WATCHING</div>
      <div class="anime-title line-clamp-2 font-bold text-[var(--ia-ink)]">
        {latestTitle ?? "观测名单等待更新"}
      </div>
    </div>

    <div class="anime-bottom">
      <span class="anime-count">
        <b class="mono">{count}</b>
        <span>records</span>
      </span>
      <span class="anime-link">
        进入番剧观测
        <Icon name="arrow" size={15} class="transition-transform group-hover:translate-x-0.5" />
      </span>
    </div>
  </div>
</a>
