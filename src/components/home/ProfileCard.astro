---
import { siteConfig } from "@/config/site";
import GlassCard from "@/components/common/GlassCard.astro";
import Icon from "@/components/common/Icon.astro";
import { normalizeEmailHref } from "@/lib/contact";
import { withBase } from "@/lib/paths";
import ContactPop from "@/components/common/ContactPop.astro";

/**
 * ProfileCard —— 首页个人资料卡（v3）。
 * 社交 / 联系入口：GitHub、Email（mailto + 正确邮件图标）、QQ、WeChat、Bilibili。
 * - QQ / WeChat 使用轻量 popover：点击弹出账号（可复制）与可选二维码，再次点击 / 点击外部 / Esc 关闭；
 * - 所有入口 hover / focus 显示 tooltip；
 * - 在 src/config/site.ts 的 links 中留空某一项即可隐藏对应入口。
 */
interface Props {
  counts: { posts: number; projects: number; archives: number; photos: number };
  class?: string;
}

const { counts, class: className = "" } = Astro.props;
const p = siteConfig.profile;
const links = siteConfig.links;
/** 头像：配置了 avatar URL 则显示图片，否则回退到 user 图标 */
const avatar = (p.avatar ?? "").trim();

const stats = [
  { label: "文章", labelEn: "POSTS", value: counts.posts, href: "/posts" },
  { label: "项目", labelEn: "PROJECTS", value: counts.projects, href: "/projects" },
  { label: "记录", labelEn: "RECORDS", value: counts.archives, href: "/timeline?view=index" },
  { label: "照片", labelEn: "PHOTOS", value: counts.photos, href: "/photos" },
];

type SocialLink = { kind: "link"; icon: string; label: string; href: string; external: boolean };
type SocialPop = { kind: "pop"; icon: string; label: string; account: string; qr?: string; note: string };
type Social = SocialLink | SocialPop;

const socials: Social[] = [];
if (links.github)
  socials.push({ kind: "link", icon: "github", label: "GitHub", href: links.github, external: true });
if (normalizeEmailHref(links.email))
  socials.push({ kind: "link", icon: "mail", label: "Email", href: normalizeEmailHref(links.email), external: false });
if (links.qq)
  socials.push({
    kind: "pop",
    icon: "qq",
    label: "QQ",
    account: links.qq,
    qr: links.qqQr || undefined,
    note: "点击账号即可复制",
  });
if (links.wechat)
  socials.push({
    kind: "pop",
    icon: "wechat",
    label: "WeChat",
    account: links.wechat,
    qr: links.wechatQr || undefined,
    note: "点击账号即可复制",
  });
if (links.bilibili)
  socials.push({ kind: "link", icon: "bilibili", label: "Bilibili", href: links.bilibili, external: true });
---

<GlassCard ticks class={`profile-card ${className}`}>
  <div class="profile-card-glow" aria-hidden="true"></div>

  <div class="profile-main">
    <a href={withBase("/about")} class="clickable avatar-ring profile-avatar shrink-0" aria-label="查看关于页面">
      <span class="avatar-core">
        {
          avatar ? (
            <img
              class="avatar-img"
              src={withBase(avatar)}
              alt={siteConfig.author}
              width={88}
              height={88}
              loading="lazy"
              decoding="async"
            />
          ) : (
            <Icon name="user" size={42} class="text-[var(--ia-star)]" />
          )
        }
      </span>
      <span class="profile-online" aria-hidden="true">
        <span></span>
      </span>
    </a>

    <div class="profile-copy min-w-0">
      <a href={withBase("/about")} class="clickable group inline-flex flex-wrap items-baseline gap-x-2">
        <span class="profile-name text-[var(--ia-ink)] transition-colors group-hover:text-[var(--ia-neon)]">
          {siteConfig.author}
        </span>
        <span class="mono profile-handle text-[var(--ia-neon)]">{p.handle}</span>
      </a>
      <p class="profile-signature text-[var(--ia-mist)]">{p.signature}</p>
      <p class="mono profile-status text-[var(--ia-mist)]">
        <span class="inline-block size-1.5 rounded-full bg-[var(--ia-neon)] shadow-[0_0_8px_var(--ia-neon)]"></span>
        {p.status} / {p.mood}
      </p>
    </div>
  </div>

  <div class="profile-stats" aria-label="档案统计">
    {
      stats.map((s) => (
        <a href={withBase(s.href)} class="profile-stat clickable group" aria-label={`查看${s.label}，共 ${s.value} 条`}>
          <b class="mono">{s.value}</b>
          <span>{s.label}</span>
          <em class="mono">{s.labelEn}</em>
        </a>
      ))
    }
  </div>

  <div class="profile-actions">
    <div class="profile-social flex items-center gap-2.5">
      {
        socials.map((s) =>
          s.kind === "link" ? (
            <a
              href={s.href}
              {...(s.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
              aria-label={s.label}
              data-tip={s.label}
              class="profile-action clickable"
            >
              <Icon name={s.icon} size={17} />
            </a>
          ) : <ContactPop icon={s.icon} label={s.label} account={s.account} qr={s.qr} />,
        )
      }
    </div>
    <span class="mono profile-save">SAVE POINT 07</span>
  </div>
</GlassCard>

<script>
  if (!document.documentElement.dataset.wlContactPop) {
  document.documentElement.dataset.wlContactPop = "1";
  /**
   * 社交 popover / 复制交互（事件委托，兼容 View Transitions）：
   * - 点击图标切换弹层；点击外部 / Esc / 再次点击关闭；
   * - 点击账号复制到剪贴板，短暂显示「已复制」。
   */
  function closeAllPops(except?: Element | null) {
    document.querySelectorAll<HTMLElement>(".profile-pop-wrap.is-open").forEach((w) => {
      if (w === except) return;
      w.classList.remove("is-open");
      const trigger = w.querySelector<HTMLElement>("[data-pop-toggle]");
      trigger?.setAttribute("aria-expanded", "false");
      if (!except && document.activeElement && w.contains(document.activeElement)) trigger?.focus();
    });
  }

  async function copyText(text: string): Promise<boolean> {
    try {
      await navigator.clipboard.writeText(text);
      return true;
    } catch {
      // 降级：临时 textarea 复制
      try {
        const ta = document.createElement("textarea");
        ta.value = text;
        ta.style.position = "fixed";
        ta.style.opacity = "0";
        document.body.appendChild(ta);
        ta.select();
        const ok = document.execCommand("copy");
        ta.remove();
        return ok;
      } catch {
        return false;
      }
    }
  }

  document.addEventListener("click", (e) => {
    const target = e.target as HTMLElement | null;

    const copyBtn = target?.closest?.<HTMLElement>("[data-copy]");
    if (copyBtn) {
      const text = copyBtn.getAttribute("data-copy") ?? "";
      void copyText(text).then((ok) => {
        if (!ok) return;
        copyBtn.classList.add("is-copied");
        window.setTimeout(() => copyBtn.classList.remove("is-copied"), 1400);
      });
      return;
    }

    const toggle = target?.closest?.<HTMLElement>("[data-pop-toggle]");
    if (toggle) {
      const wrap = toggle.closest(".profile-pop-wrap");
      if (!wrap) return;
      const open = wrap.classList.toggle("is-open");
      toggle.setAttribute("aria-expanded", open ? "true" : "false");
      closeAllPops(wrap);
      if (open) (wrap.querySelector(".profile-pop") as HTMLElement | null)?.focus();
      return;
    }

    if (!target?.closest?.(".profile-pop")) closeAllPops();
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeAllPops();
  });

  document.addEventListener("astro:page-load", () => closeAllPops());
  }
</script>
