---
import { siteConfig } from "@/config/site";
import GlassCard from "@/components/common/GlassCard.astro";
import Icon from "@/components/common/Icon.astro";
import { withBase } from "@/lib/paths";

interface Props {
  counts: { posts: number; projects: number; archives: number; photos: number };
  class?: string;
}

const { counts, class: className = "" } = Astro.props;
const p = siteConfig.profile;

const stats = [
  { label: "文章", labelEn: "POSTS", value: counts.posts, href: "/posts" },
  { label: "项目", labelEn: "PROJECTS", value: counts.projects, href: "/projects" },
  { label: "档案", labelEn: "ARCHIVES", value: counts.archives, href: "/archive" },
  { label: "照片", labelEn: "PHOTOS", value: counts.photos, href: "/photos" },
];

const iconLinks = [
  { icon: "github", label: "GitHub", href: siteConfig.links.github, external: true },
  { icon: "post", label: "Email", href: siteConfig.links.email, external: false },
  { icon: "about", label: "About", href: withBase("/about"), external: false },
].filter((l) => l.href);
---

<GlassCard ticks class={`profile-card ${className}`}>
  <div class="profile-card-glow" aria-hidden="true"></div>

  <div class="profile-main">
    <a href={withBase("/about")} class="clickable avatar-ring profile-avatar shrink-0" aria-label="查看关于页面">
      <span class="avatar-core">
        <Icon name="user" size={42} class="text-[var(--ia-star)]" />
      </span>
      <span class="profile-online" aria-hidden="true">
        <span></span>
      </span>
    </a>

    <div class="profile-copy min-w-0">
      <a href={withBase("/about")} class="clickable group inline-flex flex-wrap items-baseline gap-x-2">
        <span class="profile-name text-[var(--ia-ink)] transition-colors group-hover:text-[var(--ia-neon)]">
          {siteConfig.author}
        </span>
        <span class="mono profile-handle text-[var(--ia-neon)]">{p.handle}</span>
      </a>
      <p class="profile-signature text-[var(--ia-mist)]">{p.signature}</p>
      <p class="mono profile-status text-[var(--ia-mist)]">
        <span class="inline-block size-1.5 rounded-full bg-[var(--ia-neon)] shadow-[0_0_8px_var(--ia-neon)]"></span>
        {p.status} / {p.mood}
      </p>
    </div>
  </div>

  <div class="profile-stats" aria-label="档案统计">
    {
      stats.map((s) => (
        <a href={withBase(s.href)} class="profile-stat clickable group" aria-label={`查看${s.label}，共 ${s.value} 条`}>
          <b class="mono">{s.value}</b>
          <span>{s.label}</span>
          <em class="mono">{s.labelEn}</em>
        </a>
      ))
    }
  </div>

  <div class="profile-actions">
    <div class="flex items-center gap-2.5">
      {
        iconLinks.map((l) => (
          <a
            href={l.href}
            {...(l.external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
            aria-label={l.label}
            title={l.label}
            class="profile-action clickable"
          >
            <Icon name={l.icon} size={17} />
          </a>
        ))
      }
    </div>
    <span class="mono profile-save">SAVE POINT 07</span>
  </div>
</GlassCard>
