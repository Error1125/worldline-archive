---
import Icon from "@/components/common/Icon.astro";
import { siteConfig } from "@/config/site";

interface Props {
  startDate: string;
  class?: string;
}

const { startDate, class: className = "" } = Astro.props;
const days = Math.max(1, Math.floor((Date.now() - new Date(startDate).getTime()) / 86_400_000));
const year = new Date().getFullYear();
const tech = ["Astro", "React", "Tailwind"];
const worldline = siteConfig.profile.worldline;
---

<div class:list={["status-strip glass flex", className]} role="contentinfo">
  <div class="status-clock mono">
    <Icon name="clock" size={16} />
    <span data-wl-clock>--:--:--</span>
  </div>

  <div class="status-main">
    <span class="status-signal">
      <span class="inline-block size-2 rounded-full bg-[var(--ia-success)]"></span>
      worldline <b>{worldline}</b> stable
    </span>
    <span class="strip-sep"></span>
    <span class="mono">running {days} days</span>
    <span class="strip-sep hidden xl:block"></span>
    <span class="hidden xl:inline">archive sync complete</span>
  </div>

  <div class="status-tags">
    {tech.map((t) => <span class="tag-chip">{t}</span>)}
    <span class="mono status-copy">© {year} {siteConfig.author}</span>
  </div>
</div>

<script>
  function fmt(n: number) {
    return String(n).padStart(2, "0");
  }

  function tick() {
    const d = new Date();
    const s = `${fmt(d.getHours())}:${fmt(d.getMinutes())}:${fmt(d.getSeconds())}`;
    document.querySelectorAll<HTMLElement>("[data-wl-clock]").forEach((el) => {
      el.textContent = s;
    });
  }

  tick();
  setInterval(tick, 1000);
</script>
