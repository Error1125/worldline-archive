---
import Icon from "@/components/common/Icon.astro";
import { siteConfig } from "@/config/site";

interface Props {
  startDate: string;
  class?: string;
}

const { startDate, class: className = "" } = Astro.props;
const configuredStart = siteConfig.archiveStartedAt || startDate;
const parts = /^(\d{4})-(\d{2})-(\d{2})$/.exec(configuredStart);
const started = parts ? new Date(Number(parts[1]), Number(parts[2]) - 1, Number(parts[3])) : null;
const now = new Date();
const today = new Date(now.getFullYear(), now.getMonth(), now.getDate());
const days = started && !Number.isNaN(started.getTime())
  ? Math.max(0, Math.floor((today.getTime() - started.getTime()) / 86_400_000))
  : null;
const year = now.getFullYear();
---

<div class:list={["status-strip glass flex", className]} role="contentinfo">
  <div class="status-clock mono">
    <Icon name="clock" size={16} />
    <span data-wl-clock>--:--:--</span>
  </div>

  <div class="status-main">
    <span class="status-signal">
      <span class="inline-block size-2 rounded-full bg-[var(--ia-success)]"></span>
      {siteConfig.archiveSyncLabel}
    </span>
    <span class="strip-sep"></span>
    <span class="mono">running {days === null ? "unavailable" : `${days} days`}</span>
  </div>

  <div class="status-tags">
    {siteConfig.footerBadges.map((badge) => <span class="tag-chip">{badge}</span>)}
    <span class="mono status-copy">© {year} {siteConfig.copyrightName}</span>
  </div>
</div>

<script>
  function fmt(n: number) {
    return String(n).padStart(2, "0");
  }

  function tick() {
    const d = new Date();
    const value = `${fmt(d.getHours())}:${fmt(d.getMinutes())}:${fmt(d.getSeconds())}`;
    document.querySelectorAll<HTMLElement>("[data-wl-clock]").forEach((element) => {
      element.textContent = value;
    });
  }

  tick();
  window.setInterval(tick, 1000);
</script>
