---
import GlassCard from "@/components/common/GlassCard.astro";
import SectionTitle from "@/components/common/SectionTitle.astro";
import MusicPlayer from "@/components/music/MusicPlayer.tsx";
import AppleMusicBadge from "@/components/music/AppleMusicBadge.astro";

/**
 * NowPlayingCard.astro —— 「正在收听」卡：嵌入 MusicPlayer island + Apple Music 预留。
 */
---

<GlassCard ticks class="flex flex-col gap-4 p-5">
  <SectionTitle labelEn="NOW PLAYING" title="正在收听" icon="music" href="/music" hrefLabel="MUSIC" />

  <MusicPlayer client:load />

  <div class="flex items-center justify-between gap-3 border-t border-[var(--ia-line)] pt-3">
    <p class="mono text-[11px] leading-relaxed text-[var(--ia-mist)]">
      // Apple Music 连接即将上线
    </p>
    <AppleMusicBadge />
  </div>
</GlassCard>
