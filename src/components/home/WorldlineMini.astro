---
import { siteConfig } from "@/config/site";
import { withBase } from "@/lib/paths";

/**
 * WorldlineMini.astro —— 世界线状态的极简条（移动端使用；桌面由 HomeStatusStrip 承担）。
 * 不再是大号仪表盘：一行「WORLDLINE 1.048596 · stable · α field」，点击进入 /timeline。
 */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
const worldline = siteConfig.profile.worldline;
---

<a
  href={withBase("/timeline")}
  class:list={["worldline-mini glass clickable group", className]}
  aria-label={`世界线 ${worldline}，稳定，点击查看时间线`}
>
  <span class="wl-mini-lamp" aria-hidden="true"></span>
  <span class="mono text-[11px] tracking-[0.14em] text-[var(--ia-mist)]">WORLDLINE</span>
  <b class="wl-mini-val mono font-semibold text-[var(--ia-ink)]">{worldline}</b>
  <span class="status-badge" style="--sb-c: var(--ia-success)">stable</span>
  <span class="mono ml-auto text-[11px] text-[var(--ia-mist)] opacity-80 transition-colors group-hover:text-[var(--ia-neon)]">
    α field →
  </span>
</a>
