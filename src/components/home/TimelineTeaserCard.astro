---
import Icon from "@/components/common/Icon.astro";
import { withBase } from "@/lib/paths";

interface Props {
  count: number;
  latest?: string;
  recent?: { title: string; typeLabel: string }[];
  class?: string;
}

const { count, latest, recent = [], class: className = "" } = Astro.props;
---

<a
  href={withBase("/timeline")}
  class:list={["teaser-card glass-card corner-ticks clickable group flex flex-col", className]}
  aria-label={`查看世界线动态，共 ${count} 条记录`}
>
  <div class="teaser-scan" aria-hidden="true"></div>

  <div class="flex items-center justify-between gap-3">
    <span class="eyebrow flex items-center gap-2">
      <Icon name="timeline" size={14} class="text-[var(--ia-neon)]" />
      WORLDLINE LOG
    </span>
    <span class="teaser-state mono">OBSERVATION</span>
  </div>

  <div class="teaser-metrics">
    <div class="teaser-count-block">
      <b class="teaser-count mono">{count}</b>
      <span>records</span>
    </div>
    {latest && <span class="teaser-latest mono">latest signal {latest}</span>}
  </div>

  <ul class="teaser-recent" aria-label="最近记录">
    {
      recent.slice(0, 2).map((r) => (
        <li>
          <span class="signal-dot" aria-hidden="true"></span>
          <span class="teaser-type mono">{r.typeLabel.split(" // ")[0]}</span>
          <span class="truncate">{r.title}</span>
        </li>
      ))
    }
  </ul>

  <span class="teaser-cta">
    查看世界线动态
    <Icon name="arrow" size={15} class="transition-transform group-hover:translate-x-0.5" />
  </span>
</a>
