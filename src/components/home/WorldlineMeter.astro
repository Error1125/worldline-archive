---
import { withBase } from "@/lib/paths";
import { getTimelineItems } from "@/lib/content";
import { getWorldlineState, WORLDLINE_STATUS_META } from "@/lib/worldline";

/**
 * WorldlineMeter.astro —— 世界线变动率观测仪（v5.0 引擎驱动版）。
 *
 * v5.0：数值不再是静态彩蛋，而由 Worldline Divergence Engine 计算：
 * - 构建期：baseValue + 近期内容贡献（类型权重 × impact × featured × 时间衰减）；
 * - 客户端：按状态档位对末几位小数做轻微跳变（stable 只动第 5~6 位，
 *   divergence 会短暂大幅跳变后回落），prefers-reduced-motion 时静止；
 * - 状态：stable / observing / unstable / divergence shift，颜色与文案随之变化；
 * - 整卡点击 → /timeline（withBase 兼容 GitHub Pages），视觉结构与 v4 保持一致。
 */
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;

const items = await getTimelineItems();
const wl = getWorldlineState(items);
const meta = WORLDLINE_STATUS_META[wl.status];
const digits = wl.value.split("");
const captionMap = {
  stable: "当前世界线稳定 · 观测值已锁定",
  observing: "持续观测中 · 存档同步正常",
  unstable: "档案更新频繁 · 观测值轻微扰动",
  divergence: "检测到密集存档写入 · 世界线漂移中",
} as const;
const tip = `世界线变动率由近 ${wl.windowDays} 天的存档写入驱动（activity ${wl.score}）。点击进入时间线。`;
---

<a
  href={withBase("/timeline")}
  class:list={["wl-meter glass-card corner-ticks clickable group", className]}
  aria-label={`世界线变动率 ${wl.value}，${captionMap[wl.status]}，点击查看时间线`}
  title={tip}
  data-wl-status={wl.status}
  data-wl-value={wl.value}
  data-wl-dynamic={wl.dynamicDisplay ? "1" : "0"}
  data-wl-jitter-from={meta.jitterFrom}
  data-wl-jitter-amp={meta.jitterAmp}
  style={`--wl-tone:${meta.tone}`}
>
  <div class="flex items-center justify-between gap-3">
    <span class="eyebrow flex items-center gap-2">
      <span class="wl-meter-lamp" aria-hidden="true" style="background: var(--wl-tone); box-shadow: 0 0 10px var(--wl-tone)"></span>
      WORLDLINE DIVERGENCE
    </span>
    <span class="mono text-[10px] tracking-[0.18em] text-[var(--ia-mist)] opacity-70">OBS-07</span>
  </div>

  <div class="wl-meter-readout" aria-hidden="true">
    <div class="wl-meter-digits mono" data-wl-digits>
      {
        digits.map((d, i) => (
          <span
            data-idx={i}
            class:list={[d !== "." && (i === 2 || i === 6) && "wl-flicker"]}
            style={`animation-delay:${(i * 173) % 1100}ms`}
          >
            {d}
          </span>
        ))
      }
    </div>
    <div class="wl-meter-rule">
      {Array.from({ length: 21 }).map((_, i) => <i class:list={[i % 5 === 0 && "is-major"]} />)}
      <b class="wl-meter-needle" data-wl-needle></b>
    </div>
  </div>

  <div class="mt-auto flex flex-wrap items-center gap-x-3 gap-y-1.5 pt-3">
    <span class="status-badge" style="--sb-c: var(--wl-tone)">{meta.label}</span>
    <span class="mono text-[11px] text-[var(--ia-mist)]">α attractor field</span>
    <span class="mono ml-auto text-[10px] text-[var(--ia-mist)] opacity-70">{captionMap[wl.status]}</span>
  </div>

  <!-- hover 彩蛋说明（精准指针设备） -->
  <span class="wl-meter-tip mono" role="tooltip">{tip}</span>
</a>

<script>
  // 世界线数值动态跳变：只在客户端演出，基准值来自构建期引擎计算。
  // stable: 第 jitterFrom(5)~6 位轻微跳动；divergence: 幅度更大且入场时有一次明显偏移后回落。
  function initMeter(root: HTMLElement) {
    if (root.dataset.wlInit === "1") return;
    root.dataset.wlInit = "1";
    if (root.dataset.wlDynamic !== "1") return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const base = parseFloat(root.dataset.wlValue || "1.048596");
    const from = parseInt(root.dataset.wlJitterFrom || "5", 10); // 从小数第 from 位开始跳
    const amp = parseInt(root.dataset.wlJitterAmp || "1", 10);
    const status = root.dataset.wlStatus || "stable";
    const digitsBox = root.querySelector<HTMLElement>("[data-wl-digits]");
    const needle = root.querySelector<HTMLElement>("[data-wl-needle]");
    if (!digitsBox) return;
    const spans = Array.from(digitsBox.querySelectorAll<HTMLElement>("span"));

    // divergence shift 入场：先大幅偏移，随后 4s 内衰减回 locked/stable 幅度
    let shiftBoost = status === "divergence" ? 60 : 0;
    const started = Date.now();

    function render(v: number) {
      const str = v.toFixed(6);
      for (let i = 0; i < spans.length && i < str.length; i++) {
        if (spans[i].textContent !== str[i]) spans[i].textContent = str[i];
      }
    }

    function tick() {
      const decay = Math.max(0, 1 - (Date.now() - started) / 4000);
      const boost = shiftBoost * decay * decay;
      // 抖动量级：10^(-from) 的 amp 倍 + divergence 入场增幅
      const unit = Math.pow(10, -from);
      const jitter = (Math.random() * 2 - 1) * unit * (amp + boost);
      render(base + jitter);
      if (needle) {
        const pct = 50 + (jitter / (unit * (amp + boost + 0.0001))) * (status === "stable" ? 4 : 14);
        needle.style.left = Math.min(92, Math.max(8, pct)) + "%";
      }
    }

    const interval = status === "divergence" ? 120 : status === "unstable" ? 300 : 900;
    tick();
    const timer = window.setInterval(tick, interval);
    document.addEventListener("astro:before-swap", () => window.clearInterval(timer), { once: true });
  }

  function boot() {
    document.querySelectorAll<HTMLElement>(".wl-meter[data-wl-status]").forEach(initMeter);
  }
  boot();
  document.addEventListener("astro:page-load", boot);
</script>

<style>
  /* unstable / divergence：边框微闪（不影响 stable 的静态观感） */
  .wl-meter[data-wl-status="unstable"],
  .wl-meter[data-wl-status="divergence"] {
    animation: wl-border-flash 2.4s ease-in-out infinite;
  }
  .wl-meter[data-wl-status="divergence"] {
    animation-duration: 1.2s;
  }
  @keyframes wl-border-flash {
    0%, 100% { box-shadow: 0 0 0 0 transparent; }
    50% { box-shadow: 0 0 18px -6px var(--wl-tone); }
  }
  @media (prefers-reduced-motion: reduce) {
    .wl-meter[data-wl-status] { animation: none; }
  }
</style>
