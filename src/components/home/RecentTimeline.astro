---
import { getTimelineItems, TYPE_META } from "@/lib/content";
import Icon from "@/components/common/Icon.astro";
import TagList from "@/components/common/TagList.astro";
import { formatDate } from "@/lib/format";

/**
 * RecentTimeline.astro —— 首页最近动态（混合所有集合，按日期倒序）。
 */
interface Props {
  limit?: number;
}
const { limit = 7 } = Astro.props;
const items = (await getTimelineItems()).slice(0, limit);

const dotColor: Record<string, string> = {
  post: "var(--ia-neon)",
  moment: "var(--ia-star)",
  bug: "var(--ia-danger)",
  project: "var(--ia-nebula)",
  anime: "var(--ia-success)",
  music: "var(--ia-warning)",
  photo: "var(--ia-mist)",
};
---

<div class="relative pl-5">
  <!-- 竖线 -->
  <span class="absolute bottom-1 left-[5px] top-1 w-px bg-gradient-to-b from-[var(--ia-line-strong)] via-[var(--ia-line)] to-transparent"></span>

  <ul class="flex flex-col gap-4">
    {
      items.map((it) => {
        const Tag = it.href ? "a" : "div";
        const color = dotColor[it.type] ?? "var(--ia-mist)";
        return (
          <li class="relative">
            <span
              class="absolute -left-[15px] top-1.5 size-2.5 rounded-full ring-2 ring-[#070a16]"
              style={`background:${color};box-shadow:0 0 8px ${color}`}
            />
            <Tag
              {...(it.href ? { href: it.href } : {})}
              class:list={[
                "group block",
                it.href && "clickable",
              ]}
            >
              <div class="flex items-center gap-2">
                <Icon name={TYPE_META[it.type].icon} size={12} style={`color:${color}`} />
                <span class="mono text-[10px] uppercase tracking-wider text-[var(--ia-mist)]">
                  {it.typeLabel}
                </span>
                <time class="ml-auto mono text-[10px] text-[var(--ia-mist)]" datetime={it.date.toISOString()}>
                  {formatDate(it.date)}
                </time>
              </div>
              <p class="mt-0.5 line-clamp-1 text-sm text-[var(--ia-ink)] transition-colors group-hover:text-[var(--ia-star)]">
                {it.title}
              </p>
              {it.description && (
                <p class="line-clamp-1 text-xs text-[var(--ia-mist)]">{it.description}</p>
              )}
              {it.tags.length > 0 && (
                <div class="mt-1.5">
                  <TagList tags={it.tags} max={3} />
                </div>
              )}
            </Tag>
          </li>
        );
      })
    }
  </ul>
</div>
