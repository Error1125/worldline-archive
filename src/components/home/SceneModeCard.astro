---
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<button
  type="button"
  data-scene-toggle
  aria-label="切换昼夜场景"
  class:list={["scene-mode-card glass-card corner-ticks clickable group", className]}
>
  <div class="flex items-center justify-between gap-3">
    <span class="eyebrow flex items-center gap-2">
      <span class="scene-dot" aria-hidden="true"></span>
      SCENE MODE
    </span>
    <span class="scene-mode-state mono" aria-hidden="true">
      <span data-when="night">NIGHT</span>
      <span data-when="day">DAY</span>
    </span>
  </div>

  <div class="scene-mode-main">
    <span class="scene-orb" aria-hidden="true">
      <span class="scene-orb-night">
        <svg width="31" height="31" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20 14.5A8 8 0 019.5 4 7 7 0 1020 14.5z" />
        </svg>
      </span>
      <span class="scene-orb-day">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="4.2" fill="currentColor" stroke="none" />
          <path d="M12 2.5v2.6M12 18.9v2.6M2.5 12h2.6M18.9 12h2.6M5 5l1.9 1.9M17.1 17.1L19 19M19 5l-1.9 1.9M6.9 17.1L5 19" />
        </svg>
      </span>
    </span>

    <div class="scene-copy min-w-0">
      <div class="scene-title font-bold text-[var(--ia-ink)]">
        <span data-when="night">夜间模式</span>
        <span data-when="day">日间模式</span>
      </div>
      <p class="scene-sub text-[var(--ia-mist)]">
        <span data-when="night">星轨观测的深夜</span>
        <span data-when="day">落樱漫舞的清晨</span>
      </p>
    </div>

    <span class="scene-switch shrink-0" aria-hidden="true">
      <span class="scene-knob"></span>
    </span>
  </div>

  <div class="scene-mode-footer mono">
    <span>tap to switch</span>
    <span>local memory on</span>
  </div>
</button>

<script>
  const KEY = "wl-scene-mode";

  function applyMode(mode: "night" | "day") {
    document.documentElement.dataset.sceneMode = mode;
    try {
      localStorage.setItem(KEY, mode);
    } catch {}
    document
      .querySelectorAll<HTMLElement>("[data-scene-toggle]")
      .forEach((b) => b.setAttribute("aria-pressed", mode === "day" ? "true" : "false"));
    window.dispatchEvent(new CustomEvent("scene-mode-change", { detail: { mode } }));
  }

  function current(): "night" | "day" {
    return document.documentElement.dataset.sceneMode === "day" ? "day" : "night";
  }

  function syncButtons() {
    const mode = current();
    document
      .querySelectorAll<HTMLElement>("[data-scene-toggle]")
      .forEach((b) => b.setAttribute("aria-pressed", mode === "day" ? "true" : "false"));
  }

  document.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement | null)?.closest?.("[data-scene-toggle]");
    if (!btn) return;
    applyMode(current() === "day" ? "night" : "day");
  });

  syncButtons();
  document.addEventListener("astro:page-load", syncButtons);
</script>
