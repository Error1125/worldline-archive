---
/**
 * SceneModeCard —— 昼夜模式卡（v3）。
 * - 整张卡是一个 <button>，点击 / Enter / Space 即切换昼夜模式；
 * - 已移除卡内独立 toggle 开关（与整卡点击重复）；
 * - 页脚提示当前点击后的目标模式（tap to switch day/night mode）；
 * - 切换与持久化逻辑由 SiteLayout 的全局 GlobalSceneModeController 承担。
 */
interface Props {
  class?: string;
}

const { class: className = "" } = Astro.props;
---

<button
  type="button"
  data-scene-toggle
  aria-label="切换昼夜场景"
  class:list={["scene-mode-card glass-card corner-ticks clickable group", className]}
>
  <div class="flex items-center justify-between gap-3">
    <span class="eyebrow flex items-center gap-2">
      <span class="scene-dot" aria-hidden="true"></span>
      SCENE MODE
    </span>
    <span class="scene-mode-state mono" aria-hidden="true">
      <span data-when="night">NIGHT</span>
      <span data-when="day">DAY</span>
    </span>
  </div>

  <div class="scene-mode-main">
    <span class="scene-orb" aria-hidden="true">
      <span class="scene-orb-night">
        <svg width="31" height="31" viewBox="0 0 24 24" fill="currentColor">
          <path d="M20 14.5A8 8 0 019.5 4 7 7 0 1020 14.5z" />
        </svg>
      </span>
      <span class="scene-orb-day">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="4.2" fill="currentColor" stroke="none" />
          <path d="M12 2.5v2.6M12 18.9v2.6M2.5 12h2.6M18.9 12h2.6M5 5l1.9 1.9M17.1 17.1L19 19M19 5l-1.9 1.9M6.9 17.1L5 19" />
        </svg>
      </span>
    </span>

    <div class="scene-copy min-w-0">
      <div class="scene-title font-bold text-[var(--ia-ink)]">
        <span data-when="night">夜间模式</span>
        <span data-when="day">日间模式</span>
      </div>
      <p class="scene-sub text-[var(--ia-mist)]">
        <span data-when="night">星轨观测的深夜</span>
        <span data-when="day">樱花漂浮的清晨</span>
      </p>
    </div>

    <span class="scene-tap-hint" aria-hidden="true">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M8 13V5.5a1.5 1.5 0 0 1 3 0V12" />
        <path d="M11 11.5v-1a1.5 1.5 0 0 1 3 0v1.5" />
        <path d="M14 12v-.5a1.5 1.5 0 0 1 3 0V14c0 4-2.5 6.5-6 6.5-2.7 0-4.3-1.2-5.6-3.4L4 13.9c-.5-.9.2-2 1.3-1.9.5 0 .9.3 1.2.7L8 14.5" />
      </svg>
    </span>
  </div>

  <div class="scene-mode-footer mono">
    <span>
      <span data-when="night">tap to switch day mode</span>
      <span data-when="day">tap to switch night mode</span>
    </span>
    <span>local memory on</span>
  </div>
</button>
