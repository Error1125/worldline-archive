---
import { getSearchIndex, TYPE_META, type ContentType } from "@/lib/content";
import Icon from "@/components/common/Icon.astro";
import { withBase } from "@/lib/paths";
import { formatDate } from "@/lib/format";

/**
 * ArchiveExplorer.astro（v4.6）—— 全站聚合搜索 / 浏览。
 * 聚合 posts / projects / photos / music / anime / moments / bugs（来自统一 search index），
 * 提供关键词搜索 + 类型过滤（带数量）+ 排序（最新 / 最早）。
 * 支持 /archive?q=xxx 预填（见 SiteLayout filter 控制器的 query-param 支持）。
 * 结果卡片统一使用 .glass-card（模式感知）。
 */
const index = await getSearchIndex();

const ACCENT: Record<ContentType, string> = {
  post: "var(--ia-neon)",
  project: "var(--ia-nebula)",
  photo: "var(--ia-blue)",
  anime: "var(--ia-success)",
  music: "var(--ia-warning)",
  bug: "var(--ia-danger)",
  moment: "var(--ia-star)",
};

const typeOrder: ContentType[] = ["post", "project", "photo", "music", "anime", "moment", "bug"];
const typeCounts = typeOrder
  .map((t) => ({ type: t, count: index.filter((d) => d.type === t).length, labelZh: TYPE_META[t].labelZh, color: ACCENT[t] }))
  .filter((t) => t.count > 0);
---

<div data-filter-root data-filter-kind="archive" data-filter-query-param="q">
  <div class="glass-card mb-8 flex flex-col gap-4 p-4 sm:p-5">
    <div class="filter-bar">
      <label class="filter-search">
        <Icon name="search" size={16} class="shrink-0 text-[var(--ia-mist)]" />
        <input
          type="search"
          data-filter-search
          placeholder="搜索全部存档：标题 / 描述 / 标签 / 类型…"
          aria-label="聚合搜索全部记录"
        />
      </label>
      <select class="filter-sort" data-filter-sort aria-label="排序方式">
        <option value="newest">最新优先</option>
        <option value="oldest">最早优先</option>
      </select>
    </div>

    <div class="filter-bar">
      <div class="filter-group" role="group" aria-label="按类型筛选">
        <button type="button" class="filter-chip" data-filter-chip data-key="type" data-value="all" data-active="true">
          全部 <span class="chip-count">{index.length}</span>
        </button>
        {
          typeCounts.map((t) => (
            <button type="button" class="filter-chip" data-filter-chip data-key="type" data-value={t.type} style={`--acc:${t.color}`}>
              <span class="chip-dot" />
              {t.labelZh} <span class="chip-count">{t.count}</span>
            </button>
          ))
        }
      </div>
      <span class="filter-count-line" data-filter-count data-filter-count-label="records">{index.length} records</span>
    </div>
  </div>

  <div class="filter-empty glass" data-filter-empty>
    <p class="text-sm text-[var(--ia-ink)]">没有找到匹配的存档</p>
    <p class="mono mt-1 text-xs text-[var(--ia-mist)] opacity-70">// no records match this query</p>
  </div>

  <div class="flex flex-col gap-3" data-filter-list>
    {
      index.map((doc) => {
        const color = ACCENT[doc.type] ?? "var(--ia-mist)";
        return (
          <a
            href={withBase(doc.href)}
            class="glass-card clickable group flex items-center gap-3 rounded-xl px-4 py-3"
            data-filter-item
            data-type={doc.type}
            data-date={doc.date}
            data-search={[doc.title, doc.description, doc.typeLabelZh, ...doc.tags].join(" ")}
          >
            <span
              class="shrink-0 rounded-md px-2 py-0.5 mono text-[10px] uppercase tracking-wider"
              style={`color:${color};border:1px solid color-mix(in srgb, ${color} 40%, transparent)`}
            >
              {doc.typeLabelZh}
            </span>
            <span class="min-w-0 flex-1">
              <span class="block truncate text-sm text-[var(--ia-ink)] transition-colors group-hover:text-[var(--ia-star)]">
                {doc.title}
              </span>
              {doc.description && (
                <span class="block truncate text-xs text-[var(--ia-mist)]">{doc.description}</span>
              )}
            </span>
            <time class="shrink-0 mono text-[10px] text-[var(--ia-mist)]" datetime={doc.date}>
              {formatDate(doc.date)}
            </time>
          </a>
        );
      })
    }
  </div>
</div>
