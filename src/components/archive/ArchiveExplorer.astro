---
import { getSearchIndex, TYPE_META, type ContentType } from "@/lib/content";
import { withBase } from "@/lib/paths";
import ObservationMotion from "@/components/archive/ObservationMotion";

const index = await getSearchIndex();
const colors: Record<ContentType, string> = { post:"var(--ia-neon)", project:"var(--ia-nebula)", photo:"var(--ia-blue)", anime:"var(--ia-success)", music:"var(--ia-warning)", bug:"var(--ia-danger)", moment:"var(--ia-star)" };
const order: ContentType[] = ["post", "project", "photo", "music", "anime", "moment", "bug"];
const items = index.map((item, index) => ({...item,id:`${item.type}:${index}:${item.href}`,href:withBase(item.href),color:colors[item.type]}));
const types = order.map((type)=>({type,label:TYPE_META[type].labelZh,count:index.filter((item)=>item.type===type).length,color:colors[type]})).filter((type)=>type.count>0);
---

<ObservationMotion client:load items={items} types={types} />
