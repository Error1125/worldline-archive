---
/**
 * AppleMusicBadge.astro —— Apple Music 外链徽标。
 * 有 url 时是外链按钮；否则显示 Coming Soon。
 */
interface Props {
  url?: string;
  class?: string;
}
const { url, class: className = "" } = Astro.props;
---

{
  url ? (
    <a
      href={url}
      target="_blank"
      rel="noopener noreferrer"
      class:list={[
        "clickable inline-flex items-center gap-1.5 rounded-full border border-[var(--ia-line)] px-3 py-1 mono text-[11px] text-[var(--ia-ink)] transition-colors hover:border-[var(--ia-neon)] hover:text-[var(--ia-neon)]",
        className,
      ]}
    >
      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M9 18V6l10-2v12" />
        <circle cx="6.5" cy="18" r="2.5" />
        <circle cx="16.5" cy="16" r="2.5" />
      </svg>
      Apple Music ↗
    </a>
  ) : (
    <span
      class:list={[
        "inline-flex items-center gap-1.5 rounded-full border border-[var(--ia-line)] px-3 py-1 mono text-[11px] text-[var(--ia-mist)] opacity-70",
        className,
      ]}
    >
      Apple Music · soon
    </span>
  )
}
