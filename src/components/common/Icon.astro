---
/**
 * Icon.astro —— 内联 SVG 图标集合。
 * 全部使用 currentColor，尺寸由 size 控制；线条风格，贴近终端 / 档案气质。
 */
interface Props {
  name: string;
  size?: number;
  class?: string;
  strokeWidth?: number;
}
const { name, size = 18, class: className = "", strokeWidth = 1.6 } = Astro.props;

// 每个图标是一段 <path>/<g> 内容，viewBox 统一 0 0 24 24
const paths: Record<string, string> = {
  home: `<path d="M3 11.5 12 4l9 7.5" /><path d="M5 10v9h14v-9" /><path d="M10 19v-5h4v5" />`,
  timeline: `<path d="M12 3v18" /><circle cx="12" cy="7" r="2.2" /><circle cx="12" cy="17" r="2.2" /><path d="M14 7h5" /><path d="M5 17h5" />`,
  post: `<path d="M6 3h9l4 4v14H6z" /><path d="M14 3v5h5" /><path d="M9 12h7" /><path d="M9 16h7" />`,
  moment: `<path d="M4 5h16v11H8l-4 3z" /><path d="M8 10h8" /><path d="M8 13h5" />`,
  archive: `<path d="M3 5h18v4H3z" /><path d="M5 9v10h14V9" /><path d="M10 13h4" />`,
  about: `<circle cx="12" cy="8" r="3.4" /><path d="M5 20c0-3.6 3.1-6 7-6s7 2.4 7 6" />`,
  anime: `<path d="M4 8l8-4 8 4-8 4z" /><path d="M4 8v6l8 4 8-4V8" /><path d="M12 12v6" />`,
  music: `<path d="M9 18V6l10-2v12" /><circle cx="6.5" cy="18" r="2.5" /><circle cx="16.5" cy="16" r="2.5" />`,
  project: `<path d="M12 3l8 4.5v9L12 21l-8-4.5v-9z" /><path d="M12 12l8-4.5" /><path d="M12 12v9" /><path d="M12 12 4 7.5" />`,
  bug: `<rect x="7" y="8" width="10" height="10" rx="5" /><path d="M12 4v4" /><path d="M4 11h3" /><path d="M17 11h3" /><path d="M4.5 17h2.5" /><path d="M17 17h2.5" /><path d="M9 5.5 10.5 7" /><path d="M15 5.5 13.5 7" />`,
  photo: `<rect x="3" y="6" width="18" height="14" rx="2" /><circle cx="12" cy="13" r="3.4" /><path d="M8 6l1.5-2h5L16 6" />`,
  search: `<circle cx="11" cy="11" r="6" /><path d="m16 16 4 4" />`,
  star: `<path d="M12 3.5l2.6 5.6 6 .8-4.4 4.1 1.1 6-5.3-2.9-5.3 2.9 1.1-6L3.4 9.9l6-.8z" />`,
  github: `<path d="M9 19c-4 1.4-4-2-5.5-2.5M15 21v-3.2c0-1 .2-1.6-.5-2.2 2.3-.3 4.5-1.1 4.5-5a3.9 3.9 0 0 0-1.1-2.7 3.6 3.6 0 0 0-.1-2.7s-.9-.3-3 1a10 10 0 0 0-5.4 0c-2.1-1.3-3-1-3-1a3.6 3.6 0 0 0-.1 2.7A3.9 3.9 0 0 0 4 12.6c0 3.9 2.2 4.7 4.5 5-.4.4-.6.9-.6 1.6V21" />`,
  terminal: `<path d="M4 5h16v14H4z" /><path d="m8 10 3 2-3 2" /><path d="M13 15h4" />`,
  lock: `<rect x="5" y="11" width="14" height="9" rx="1.6" /><path d="M8 11V8a4 4 0 0 1 8 0v3" /><path d="M12 15v2" />`,
  user: `<circle cx="12" cy="8" r="3.4" /><path d="M5 20c0-3.6 3.1-6 7-6s7 2.4 7 6" />`,
  arrow: `<path d="M5 12h14" /><path d="m13 6 6 6-6 6" />`,
  clock: `<circle cx="12" cy="12" r="8" /><path d="M12 8v4l2.5 2" />`,
  sparkle: `<path d="M12 3v4M12 17v4M3 12h4M17 12h4" /><path d="M12 9l1 2 2 1-2 1-1 2-1-2-2-1 2-1z" />`,
};

const inner = paths[name] ?? paths.star;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={`ia-icon ${className}`}
  aria-hidden="true"
  set:html={inner}
/>
